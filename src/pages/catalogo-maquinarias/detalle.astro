---
import Layout from "src/layouts/Layout.astro";
import ProductPage from "src/components/products/ProductPage";

const productSlug = Astro.url.searchParams.get("link");

const safeSlug =
  productSlug?.trim().toLowerCase().replace(/[^a-z0-9-]/g, "") ?? null;

const canonicalUrl = safeSlug
  ? `https://tamimaquinarias.com/catalogo-maquinarias/${safeSlug}/`
  : "https://tamimaquinarias.com/catalogo-maquinarias/";

// Pasar el slug limpio al componente para que use el mismo valor en cliente y servidor
const initialProduct = safeSlug ? { link: safeSlug } : undefined;
---

<Layout
  title="Detalle de Producto - Tami Maquinarias"
  description="Consulta las características, aplicaciones y beneficios de nuestras maquinarias y equipos comerciales."
  keywords=""
  canonicalUrl={canonicalUrl}
>
<ProductPage producto={initialProduct} client:load />
</Layout>