---
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
import ScrollModal from "../../components/ui/ScrollModal.tsx";
---

<LayoutAdmin title="POPUPS">
  <div class="p-0 h-full w-full bg-gray-50 dark:bg-gray-900 overflow-x-hidden">
    
    <div class="bg-teal-500 rounded-t-xl p-4 flex justify-between items-center shadow-lg relative z-10 w-full">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <div>
          <h1 class="text-2xl font-bold text-white tracking-wide drop-shadow-sm">Configuración de Pop-ups</h1>
          <p class="text-teal-100 text-sm">Personaliza el aspecto de tus ventanas emergentes</p>
        </div>
      </div>
    </div>

    <!-- Contenido Principal -->
    <div class="bg-white dark:bg-gray-800 rounded-b-xl shadow-xl border border-t-0 p-8 border-gray-200 dark:border-gray-700 min-h-[60vh]">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-8">
            <!-- Columna Izquierda: Formulario de Opciones -->
            <div class="space-y-6 lg:border-r lg:border-gray-200 lg:dark:border-gray-700 lg:pr-8">
                <div class="flex gap-2 mb-6 border-b pb-2">
                  <button id="tabPopups" class="px-4 py-2 rounded-md bg-teal-500 text-white text-sm font-medium">
                    Pop-ups
                  </button>

                  <button id="tabWhatsapp" class="px-4 py-2 rounded-md text-gray-500 hover:bg-gray-100 text-sm font-medium">
                    WhatsApp
                  </button>

                  <button id="tabCorreo" class="px-4 py-2 rounded-md text-gray-500 hover:bg-gray-100 text-sm font-medium">
                    Correo
                  </button>
                </div>

                <div class="space-y-6">
                    <div id="contentPopups">

                        <!-- Añadir Imagen 1 -->
                        <div class="flex items-start justify-between p-4 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors">
                            <div>
                                <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg">Añadir Imagen 1</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Sube una imagen promocional para tu popup. Resolución recomendada: 448x550px.</p>
                            </div>
                            <div class="ml-4 flex-shrink-0 flex items-center space-x-2">
                                <input type="hidden" name="delete_popupImage1" id="delete_popupImage1" value="0">
                                <input type="file" id="popupImage1" accept="image/*" class="hidden">
                                <button type="button" onclick="document.getElementById('popupImage1').click()" class="inline-flex items-center px-4 py-2 border border-teal-500 text-sm font-medium rounded-md text-teal-600 bg-white hover:bg-teal-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 transition-colors">
                                    Subir Archivo
                                    <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 -mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                    </svg>
                                </button>
                                <button type="button" id="clearImage1" class="hidden text-red-500 hover:text-red-700 text-sm font-semibold p-2" title="Borrar Imagen 1">
                                    ✕
                                </button>
                            </div>
                        </div>

                        <!-- Añadir Imagen 2 -->
                        <div class="flex items-start justify-between p-4 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors">
                            <div>
                                <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg">Añadir Imagen 2</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Segunda imagen para el popup (mitad derecha). Resolución recomendada: 448x550px.</p>
                            </div>
                            <div class="ml-4 flex-shrink-0 flex items-center space-x-2">
                                <input type="hidden" name="delete_popupImage2" id="delete_popupImage2" value="0">
                                <input type="file" id="popupImage2" accept="image/*" class="hidden">
                                <button type="button" onclick="document.getElementById('popupImage2').click()" class="inline-flex items-center px-4 py-2 border border-teal-500 text-sm font-medium rounded-md text-teal-600 bg-white hover:bg-teal-50">
                                    Subir Imagen 2
                                </button>
                                <button type="button" id="clearImage2" class="hidden text-red-500 hover:text-red-700 text-sm font-semibold p-2" title="Borrar Imagen 2">
                                    ✕
                                </button>
                            </div>
                        </div>

                        <!-- Añadir Imagen para Móvil -->
                        <div class="flex items-start justify-between p-4 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors">
                            <div>
                                <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg">Añadir Imagen Móvil</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Imagen para vista en dispositivos móviles. Resolución recomendada: 448x640px.</p>
                            </div>
                            <div class="ml-4 flex-shrink-0 flex items-center space-x-2">
                                <input type="hidden" name="delete_popupImageMobile" id="delete_popupImageMobile" value="0">
                                <input type="file" id="popupImageMobile" accept="image/*" class="hidden">
                                <button type="button" onclick="document.getElementById('popupImageMobile').click()" class="inline-flex items-center px-4 py-2 border border-teal-500 text-sm font-medium rounded-md text-teal-600 bg-white hover:bg-teal-50">
                                    Subir Imagen Móvil
                                </button>
                                <button type="button" id="clearImageMobile" class="hidden text-red-500 hover:text-red-700 text-sm font-semibold p-2" title="Borrar Imagen Móvil">
                                    ✕
                                </button>
                            </div>
                        </div>

                        <!-- Añadir Imagen Móvil 2 -->
                        <div class="flex items-start justify-between p-4 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors">
                            <div>
                                <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg">Añadir Imagen Móvil 2</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Segunda imagen para vista en dispositivos móviles (abajo). Resolución recomendada: 448x640px.</p>
                            </div>
                            <div class="ml-4 flex-shrink-0 flex items-center space-x-2">
                                <input type="hidden" name="delete_popupImageMobile2" id="delete_popupImageMobile2" value="0">
                                <input type="file" id="popupImageMobile2" accept="image/*" class="hidden">
                                <button type="button" onclick="document.getElementById('popupImageMobile2').click()" class="inline-flex items-center px-4 py-2 border border-teal-500 text-sm font-medium rounded-md text-teal-600 bg-white hover:bg-teal-50">
                                    Subir Imagen Móvil 2
                                </button>
                                <button type="button" id="clearImageMobile2" class="hidden text-red-500 hover:text-red-700 text-sm font-semibold p-2" title="Borrar Imagen Móvil 2">
                                    ✕
                                </button>
                            </div>
                        </div>

                        <!-- Cambiar Color de Texto del Botón -->
                        <div class="flex items-start justify-between p-4 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors">
                             <div>
                                <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg">Cambiar Color de Texto del Botón</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Define el color del texto que estará dentro del botón principal.</p>
                            </div>
                            <div class="ml-4 flex-shrink-0 flex items-center space-x-3">
                                 <div class="relative w-10 h-10 rounded-full overflow-hidden border-2 border-gray-200 shadow-sm ring-2 ring-gray-100 dark:border-gray-600 dark:ring-gray-700">
                                     <input type="color" id="btnTextColor" value="#ffffff" class="absolute -top-2 -left-2 w-16 h-16 cursor-pointer" />
                                 </div>
                                 <label for="btnTextColor" class="text-sm text-gray-500 hover:text-teal-600 underline cursor-pointer">Elegir color</label>
                            </div>
                        </div>

                        <!-- Cambiar Color de Botón -->
                        <div class="flex items-start justify-between p-4 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors">
                             <div>
                                <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg">Cambiar Color del Botón</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Elige el color de fondo para los botones de acción principal.</p>
                            </div>
                            <div class="ml-4 flex-shrink-0 flex items-center space-x-3">
                                 <div class="relative w-10 h-10 rounded-full overflow-hidden border-2 border-gray-200 shadow-sm ring-2 ring-gray-100 dark:border-gray-600 dark:ring-gray-700">
                                     <input type="color" id="btnBgColor" value="#14b8a6" class="absolute -top-2 -left-2 w-16 h-16 cursor-pointer" />
                                 </div>
                                 <label for="btnBgColor" class="text-sm text-gray-500 hover:text-teal-600 underline cursor-pointer">Elegir color</label>
                            </div>
                        </div>

                        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100 mt-10 mb-6 border-b pb-2">Tiempo de Aparición de Pop-ups</h2>

                        <!-- Tiempo de Aparición del Pop-up de Inicio -->
                        <div class="flex items-start justify-between p-4 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors">
                             <div>
                                <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg">Pop-up de Inicio</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Elige el tiempo que tardará en aparecer el primer pop-up al entrar a la pagina de Inicio.</p>
                            </div>
                            <div class="ml-4 flex-shrink-0 flex items-center space-x-3">
                                 <div class="relative flex items-center">
                                     <select id="popupInicioDelay" class="block w-40 rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm p-2.5 border">
                                         <option value="1" selected>1 minuto</option>
                                         <option value="2">2 minutos</option>
                                         <option value="3">3 minutos</option>
                                         <option value="4">4 minutos</option>
                                         <option value="5">5 minutos</option>
                                         <option value="6">6 minutos</option>
                                         <option value="7">7 minutos</option>
                                         <option value="8">8 minutos</option>
                                         <option value="9">9 minutos</option>
                                         <option value="10">10 minutos</option>
                                     </select>
                                 </div>
                            </div>
                        </div>

                        <!-- Tiempo de Aparición del Pop-up de Productos -->
                        <div class="flex items-start justify-between p-4 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors">
                             <div>
                                <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg">Pop-ups de Productos</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Elige el tiempo que tardarán en aparecer los pop-ups al ver el detalle de los productos.</p>
                            </div>
                            <div class="ml-4 flex-shrink-0 flex items-center space-x-3">
                                 <div class="relative flex items-center">
                                     <select id="popupProductosDelay" class="block w-40 rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm p-2.5 border">
                                         <option value="60" selected>1 minuto</option>
                                         <option value="120">2 minutos</option>
                                         <option value="180">3 minutos</option>
                                         <option value="240">4 minutos</option>
                                         <option value="300">5 minutos</option>
                                         <option value="360">6 minutos</option>
                                         <option value="420">7 minutos</option>
                                         <option value="480">8 minutos</option>
                                         <option value="540">9 minutos</option>
                                         <option value="600">10 minutos</option>
                                     </select>
                                 </div>
                            </div>
                        </div>

                    </div>

                    <div id="contentWhatsapp" class="hidden">
                        <!-- Editar Mensaje de WhatsApp -->
                        <div class="flex flex-col p-6 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors gap-6">
                            <div class="w-full">
                               <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg flex items-center gap-2">
                                 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="text-green-500 shrink-0" viewBox="0 0 16 16">
                                    <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
                                 </svg>
                                 WhatsApp
                               </h3>
                               <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 mb-4">Configura la imagen y mensaje predeterminado que se enviarán.</p>
                               <div class="flex items-center space-x-2">
                                   <input type="hidden" name="delete_whatsappImage" id="delete_whatsappImage" value="0">
                                   <input type="file" id="whatsappImage" accept="image/*" class="hidden">
                                   <button type="button" onclick="document.getElementById('whatsappImage').click()" class="inline-flex items-center px-4 py-2 bg-[#128C7E] text-sm font-medium rounded-md text-white hover:bg-[#075E54] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#128C7E] transition-colors shadow-sm">
                                        Añadir Imagen a WhatsApp
                                        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                        </svg>
                                    </button>
                                    <button type="button" id="clearWhatsappImage" class="hidden text-red-500 hover:text-red-700 text-sm font-semibold p-2" title="Borrar Imagen WhatsApp">
                                        ✕
                                    </button>
                               </div>
                            </div>
                            <div class="w-full">
                                <label for="whatsappMessage" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Mensaje de WhatsApp</label>
                                <textarea 
                                    id="whatsappMessage"
                                    rows="4" 
                                    class="block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 shadow-sm focus:border-green-500 focus:ring-green-500 sm:text-sm p-3 border" 
                                    placeholder="Escribe tu mensaje aquí... Ej: ¡Hola! Me gustaría obtener el descuento del popup..."
                                >¡Hola! Me gustaría obtener más información sobre la promoción.</textarea>
                            </div>
                        </div>
                    </div>

                    <div id="contentCorreo" class="hidden">
                        <!-- Editar Mensaje de Correo -->
                        <div class="flex flex-col p-6 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors gap-6">
                            <div class="w-full">
                               <h3 class="font-medium text-gray-900 dark:text-gray-100 text-lg flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                                   <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                   <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                                </svg>
                                Correo Electrónico
                               </h3>
                               <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 mb-4">Configura el título, mensaje e imagen para los emails.</p>
                               <div class="flex items-center space-x-2">
                                   <input type="hidden" name="delete_emailImage" id="delete_emailImage" value="0">
                                   <input type="file" id="emailImage" accept="image/*" class="hidden">
                                   <button type="button" onclick="document.getElementById('emailImage').click()" class="inline-flex items-center px-4 py-2 bg-blue-500 text-sm font-medium rounded-md text-white hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors shadow-sm">
                                        Añadir Imagen Adjunta
                                        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                                        </svg>
                                    </button>
                                    <button type="button" id="clearEmailImage" class="hidden text-red-500 hover:text-red-700 text-sm font-semibold p-2" title="Borrar Imagen Correo">
                                        ✕
                                    </button>
                               </div>
                            </div>
                            <div class="w-full space-y-3">
                                <div>
                                     <label for="emailTitle" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Título / Asunto</label>
                                     <input 
                                        type="text" 
                                        id="emailTitle" 
                                        class="block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm p-3 border" 
                                        placeholder="Ej: Información sobre Promoción Exclusiva"
                                        value="Solicitud de información - Popup Web"
                                     />
                                </div>
                                <div>
                                    <label for="emailBody" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Mensaje de Correo</label>
                                    <textarea 
                                        id="emailBody"
                                        rows="3" 
                                        class="block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm p-3 border" 
                                        placeholder="Escribe el cuerpo del correo aquí..."
                                    >¡Hola! Me interesa la oferta mostrada en su página web y me gustaría recibir más detalles.</textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            
                <div class="mt-8 flex flex-col gap-2">
                     <p id="popupStatus" class="text-sm text-gray-600 dark:text-gray-300" role="status" aria-live="polite"></p>
                     <div class="flex justify-end">
                        <button type="button" id="btnGuardarPopups" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-teal-600 hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 transition-colors disabled:opacity-50">
                            Guardar Cambios
                        </button>
                     </div>
                </div>
            </div>

            <!-- Columna Derecha: Vista Previa -->
            <div class="lg:pl-4">
              <div class="sticky top-8">
                  <div class="flex items-center justify-between mb-6 border-b pb-2">
                      <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100">Vista Previa</h2>
                      <div id="previewModesToggle" class="flex bg-gray-100 dark:bg-gray-800 p-1 rounded-lg">
                          <button id="btnDesktop" class="px-3 py-1.5 text-sm font-medium rounded-md bg-white dark:bg-gray-700 text-teal-600 shadow-sm transition-colors flex items-center gap-2">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                              </svg>
                              Escritorio
                          </button>
                          <button id="btnMobile" class="px-3 py-1.5 text-sm font-medium rounded-md text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 transition-colors flex items-center gap-2">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                              </svg>
                              Móvil
                          </button>
                      </div>
                  </div>
                  
                 <div id="previewStage" class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 flex justify-center items-center relative overflow-hidden min-h-[500px] transition-all duration-300">

                    <!-- Fondo oscuro (oculto por defecto) -->
                    <div id="previewOverlay" class="hidden absolute inset-0 bg-black/40 dark:bg-black/60 z-0"></div>

                    <!-- CONTENEDOR RELATIVO -->
                    <div id="previewScrollModalContainer" class="relative z-10 w-full min-h-[500px] flex justify-center items-center">
                        <ScrollModal client:only="react" isPreview={true} />
                    </div>

                    <!-- ================= WHATSAPP REALISTIC PREVIEW ================= -->
                    <div id="previewWhatsapp" class="hidden absolute inset-0 flex justify-center items-center z-20 overflow-hidden">
                        <div class="bg-[#e5ddd5] rounded-xl shadow-2xl w-[320px] h-[500px] flex flex-col overflow-hidden border border-gray-300 relative scale-90 sm:scale-100">
                            <!-- Header -->
                            <div class="bg-[#075e54] p-3 flex items-center gap-3 text-white shadow-md shrink-0 relative z-10">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                                </svg>
                                <div id="previewWhatsappProfileImg" class="w-10 h-10 bg-gray-200 rounded-full flex items-center justify-center shrink-0 overflow-hidden border border-white/20">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="font-bold text-sm leading-tight truncate">Jhon Doe</div>
                                    <div class="text-[10px] opacity-70">En línea</div>
                                </div>
                            </div>

                            <!-- Chat Body -->
                            <div class="flex-1 p-4 overflow-y-auto space-y-4 relative">
                                <div class="bg-white p-3 rounded-lg rounded-tl-none shadow-sm max-w-[85%] text-[13px] relative z-10 text-gray-800">
                                    Hola!, me gustaria saber mas informacion de....
                                    <div class="text-[10px] text-gray-400 mt-1 text-right">10:45 AM</div>
                                </div>
                                <div class="self-end bg-[#dcf8c6] p-3 rounded-lg rounded-tr-none shadow-sm max-w-[85%] text-[13px] relative z-10 ml-auto mr-0 text-gray-800">
                                    <div id="previewWhatsappText" class="w-full break-words">¡Hola! Me gustaría obtener más información sobre la promoción.</div>
                                    <div class="flex items-center justify-end gap-1 mt-1 shrink-0">
                                        <div class="text-[10px] text-gray-500">10:46 AM</div>
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-blue-500" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M12.354 4.354a.5.5 0 0 0-.708-.708L5 10.293 1.854 7.146a.5.5 0 1 0-.708.708l3.5 3.5a.5.5 0 0 0 .708 0l7-7zm-4.208 7-.896-.897.707-.707.543.543 6.646-6.647a.5.5 0 0 1 .708.708l-7 7a.5.5 0 0 1-.708 0z"/>
                                        </svg>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================= CORREO REALISTIC PREVIEW ================= -->
                    <div id="previewCorreo" class="hidden absolute inset-0 flex justify-center items-center z-20 overflow-hidden">
                        <div class="bg-white w-full h-full flex flex-col overflow-hidden relative transition-all duration-300">
                            <div class="bg-[#404040] p-3 px-6 flex items-center justify-between text-white text-sm">
                                <span class="font-medium text-base">Mensaje nuevo</span>
                            </div>
                            <div class="px-6 py-3 border-b border-gray-100 flex items-center gap-6 text-sm">
                                <span class="text-gray-400 w-16">Para</span>
                                <span class="text-gray-700 font-medium">contacto@tami.com</span>
                            </div>
                            <div class="px-6 py-3 border-b border-gray-100 flex items-center gap-6 text-sm">
                                <span class="text-gray-400 w-16">Asunto</span>
                                <div id="previewCorreoTitle" class="text-gray-800 font-medium flex-1 text-base">Solicitud de información - Popup Web</div>
                            </div>
                            <div id="previewCorreoBody" class="p-10 sm:p-12 flex-1 overflow-y-auto text-base sm:text-lg text-gray-800 whitespace-pre-wrap leading-relaxed min-h-[300px]">¡Hola! Me interesa la oferta mostrada...</div>
                        </div>
                    </div>

                 </div>
              </div>
            </div>
        </div>
    </div>
  </div>

  <style is:global>
      /* Mobile Mode Styles */
      #previewContainer[data-mode="mobile"]:not(.hidden) {
          width: 100%;
          max-width: 24rem;
          display: flex;
          flex-direction: column;
      }
      
      #previewStage.is-gmail {
          background: white !important;
          padding: 0 !important;
          border: none !important;
          box-shadow: none !important;
      }
      #previewStage.is-gmail #previewOverlay {
          display: none !important;
      }

      /* Escalas para las vistas previas */
      #previewScrollModalContainer {
          transform: scale(0.85);
          transform-origin: center center;
          transition: transform 0.3s ease;
      }

      #previewStage.is-mobile-view #previewScrollModalContainer {
          transform: scale(0.75);
          margin: 2rem 0;
      }
      
      @media (min-width: 1024px) {
          #previewScrollModalContainer {
              transform: scale(0.9);
          }
          #previewStage.is-mobile-view #previewScrollModalContainer {
              transform: scale(0.85);
          }
      }
  </style>
</LayoutAdmin>

<script>
import { getPopupSettings, updatePopupSettings, isHexColor } from "../../lib/api/popupSettings";

function initTabs() {
  const tabPopups = document.getElementById("tabPopups");
  const tabWhatsapp = document.getElementById("tabWhatsapp");
  const tabCorreo = document.getElementById("tabCorreo");

  const btnDesktop = document.getElementById("btnDesktop");
  const btnMobile = document.getElementById("btnMobile");

  const contentPopups = document.getElementById("contentPopups");
  const contentWhatsapp = document.getElementById("contentWhatsapp");
  const contentCorreo = document.getElementById("contentCorreo");

  const previewScrollModalContainer = document.getElementById("previewScrollModalContainer");
  const previewWhatsapp = document.getElementById("previewWhatsapp");
  const previewCorreo = document.getElementById("previewCorreo");
  const previewOverlay = document.getElementById("previewOverlay");
  const previewModesToggle = document.getElementById("previewModesToggle");
  const previewStage = document.getElementById("previewStage");
  const statusElement = document.getElementById("popupStatus");

  let currentMode = "desktop";

  if (!tabPopups || !tabWhatsapp || !tabCorreo || !btnDesktop || !btnMobile) {
    setTimeout(initTabs, 200);
    return;
  }

  const tabs = [tabPopups, tabWhatsapp, tabCorreo];
  const contents = [contentPopups, contentWhatsapp, contentCorreo];

  function updatePreview(settings = {}, mode = null) {
    console.log("[popups.astro] Dispatching updatePreview:", { settings, mode });
    window.dispatchEvent(new CustomEvent("update-popup-preview", {
      detail: { settings, mode }
    }));
  }

  function setStatus(message, type = "idle") {
    if (!statusElement) return;
    statusElement.textContent = message;
    statusElement.className = "text-sm mt-2";
    if (type === "success") statusElement.classList.add("text-teal-600");
    else if (type === "error") statusElement.classList.add("text-red-500");
    else if (type === "loading") statusElement.classList.add("text-amber-500");
    else statusElement.classList.add("text-gray-600", "dark:text-gray-300");
  }

  function activarTab(tab, content, type) {
    tabs.forEach(t => {
        t.classList.remove("bg-teal-600", "text-white", "dark:bg-teal-500", "bg-teal-500");
        t.classList.add("text-gray-500", "dark:text-gray-400", "hover:text-gray-700", "dark:hover:text-gray-200");
    });
    contents.forEach(c => c.classList.add("hidden"));
    if (previewWhatsapp) previewWhatsapp.classList.add("hidden");
    if (previewCorreo) previewCorreo.classList.add("hidden");

    tab.classList.remove("text-gray-500", "dark:text-gray-400", "hover:text-gray-700", "dark:hover:text-gray-200");
    tab.classList.add("bg-teal-600", "text-white", "dark:bg-teal-500");
    content.classList.remove("hidden");

    if (type === 'popups') {
        if (previewScrollModalContainer) previewScrollModalContainer.classList.remove("hidden");
        updatePreview({ }, currentMode);
        if (previewOverlay) previewOverlay.classList.add("hidden");
        if (previewModesToggle) previewModesToggle.classList.remove("hidden");
        if (previewStage) {
            previewStage.classList.remove("is-gmail");
            if (currentMode === 'mobile') previewStage.classList.add("is-mobile-view");
            else previewStage.classList.remove("is-mobile-view");
        }
    } else if (type === 'whatsapp') {
        if (previewScrollModalContainer) previewScrollModalContainer.classList.add("hidden");
        if (previewWhatsapp) previewWhatsapp.classList.remove("hidden");
        if (previewOverlay) previewOverlay.classList.add("hidden");
        if (previewModesToggle) previewModesToggle.classList.add("hidden");
        if (previewStage) previewStage.classList.remove("is-gmail");
    } else if (type === 'correo') {
        if (previewScrollModalContainer) previewScrollModalContainer.classList.add("hidden");
        if (previewCorreo) previewCorreo.classList.remove("hidden");
        if (previewStage) previewStage.classList.add("is-gmail");
        if (previewOverlay) previewOverlay.classList.add("hidden");
        if (previewModesToggle) previewModesToggle.classList.add("hidden");
    } else if (type === 'correo') {
        if (previewScrollModalContainer) previewScrollModalContainer.classList.add("hidden");
        if (previewCorreo) previewCorreo.classList.remove("hidden");
        if (previewStage) previewStage.classList.add("is-gmail");
        if (previewOverlay) previewOverlay.classList.add("hidden");
        if (previewModesToggle) previewModesToggle.classList.add("hidden");
    }
    
    // Toggle "Full Stage" mode for Gmail
    if (type !== 'correo') {
        if (previewStage) previewStage.classList.remove("is-gmail");
    }
  }

  tabPopups.onclick = () => activarTab(tabPopups, contentPopups, 'popups');
  tabWhatsapp.onclick = () => activarTab(tabWhatsapp, contentWhatsapp, 'whatsapp');
  tabCorreo.onclick = () => activarTab(tabCorreo, contentCorreo, 'correo');

  activarTab(tabPopups, contentPopups, 'popups');

  btnDesktop.onclick = () => {
      currentMode = "desktop";
      btnDesktop.classList.add("bg-white", "text-teal-600", "shadow-sm");
      btnDesktop.classList.remove("text-gray-500");
      btnMobile.classList.remove("bg-white", "text-teal-600", "shadow-sm");
      btnMobile.classList.add("text-gray-500");
      if (previewStage) previewStage.classList.remove("is-mobile-view");
      updatePreview({}, "desktop");
  };

  btnMobile.onclick = () => {
      currentMode = "mobile";
      btnMobile.classList.add("bg-white", "text-teal-600", "shadow-sm");
      btnMobile.classList.remove("text-gray-500");
      btnDesktop.classList.remove("bg-white", "text-teal-600", "shadow-sm");
      btnDesktop.classList.add("text-gray-500");
      if (previewStage) previewStage.classList.add("is-mobile-view");
      updatePreview({}, "mobile");
  };

  // SYNC INPUTS TO PREVIEW
  const textareaWhatsapp = document.getElementById("whatsappMessage");
  const previewWhatsappText = document.getElementById("previewWhatsappText");
  textareaWhatsapp?.addEventListener("input", () => {
    if (previewWhatsappText) previewWhatsappText.textContent = textareaWhatsapp.value;
  });

  const emailTitle = document.getElementById("emailTitle");
  const emailBody = document.getElementById("emailBody");
  const previewCorreoTitle = document.getElementById("previewCorreoTitle");
  const previewCorreoBody = document.getElementById("previewCorreoBody");
  emailTitle?.addEventListener("input", () => {
    if (previewCorreoTitle) previewCorreoTitle.textContent = emailTitle.value;
  });
  emailBody?.addEventListener("input", () => {
    if (previewCorreoBody) previewCorreoBody.textContent = emailBody.value;
  });

  // Colores del Botón
  const btnBgColorInput = document.getElementById("btnBgColor");
  const btnTextColorInput = document.getElementById("btnTextColor");

  if (btnBgColorInput) {
      console.log("[popups.astro] btnBgColorInput found, adding listeners");
      const handleBgChange = () => {
          const val = (btnBgColorInput as HTMLInputElement).value;
          console.log("[popups.astro] BgColor changed:", val);
          updatePreview({ button_bg_color: val });
          localStorage.setItem('popupBtnBgColor', val);
      };
      btnBgColorInput.addEventListener("input", handleBgChange);
      btnBgColorInput.addEventListener("change", handleBgChange);
  }

  if (btnTextColorInput) {
      console.log("[popups.astro] btnTextColorInput found, adding listeners");
      const handleTextChange = () => {
          const val = (btnTextColorInput as HTMLInputElement).value;
          console.log("[popups.astro] TextColor changed:", val);
          updatePreview({ button_text_color: val });
          localStorage.setItem('popupBtnTextColor', val);
      };
      btnTextColorInput.addEventListener("input", handleTextChange);
      btnTextColorInput.addEventListener("change", handleTextChange);
  }

  const popupInicioDelayInput = document.getElementById("popupInicioDelay");
  popupInicioDelayInput?.addEventListener("change", () => {
    const val = (popupInicioDelayInput as HTMLSelectElement).value;
    updatePreview({ popup_start_delay_minutes: parseInt(val) });
    localStorage.setItem('popupDelay', val);
  });

  // IMAGE UPLOADS
  const popupImage1 = document.getElementById("popupImage1");
  const popupImage2 = document.getElementById("popupImage2");
  const popupImageMobile = document.getElementById("popupImageMobile");
  const popupImageMobile2 = document.getElementById("popupImageMobile2");
  const whatsappImage = document.getElementById("whatsappImage");
  const emailImage = document.getElementById("emailImage");

  const clearImage1 = document.getElementById("clearImage1");
  const clearImage2 = document.getElementById("clearImage2");
  const clearImageMobile = document.getElementById("clearImageMobile");
  const clearImageMobile2 = document.getElementById("clearImageMobile2");

  function handleImageUpload(input, callback) {
      if (input && input.files && input.files[0]) {
          const reader = new FileReader();
          reader.onload = (e) => callback(e.target.result);
          reader.readAsDataURL(input.files[0]);
      }
  }

  popupImage1?.addEventListener("change", function() {
      handleImageUpload(this, (url) => {
          updatePreview({ popup_image_url: url });
          clearImage1?.classList.remove("hidden");
          localStorage.setItem('popupImage', url);
          const del = document.getElementById("delete_popupImage1") as HTMLInputElement;
          if (del) del.value = "0";
      });
  });
  clearImage1?.addEventListener("click", () => {
      if (popupImage1) (popupImage1 as HTMLInputElement).value = "";
      updatePreview({ popup_image_url: null });
      clearImage1.classList.add("hidden");
      localStorage.removeItem('popupImage');
      const del = document.getElementById("delete_popupImage1") as HTMLInputElement;
      if (del) del.value = "1";
  });

  popupImage2?.addEventListener("change", function() {
      handleImageUpload(this, (url) => {
          updatePreview({ popup_image2_url: url });
          clearImage2?.classList.remove("hidden");
          localStorage.setItem('popupImage2', url);
          const del = document.getElementById("delete_popupImage2") as HTMLInputElement;
          if (del) del.value = "0";
      });
  });
  clearImage2?.addEventListener("click", () => {
      if (popupImage2) (popupImage2 as HTMLInputElement).value = "";
      updatePreview({ popup_image2_url: null });
      clearImage2.classList.add("hidden");
      localStorage.removeItem('popupImage2');
      const del = document.getElementById("delete_popupImage2") as HTMLInputElement;
      if (del) del.value = "1";
  });

  popupImageMobile?.addEventListener("change", function() {
      handleImageUpload(this, (url) => {
          updatePreview({ popup_mobile_image_url: url });
          clearImageMobile?.classList.remove("hidden");
          localStorage.setItem('popupImageMobile', url);
          const del = document.getElementById("delete_popupImageMobile") as HTMLInputElement;
          if (del) del.value = "0";
      });
  });
  clearImageMobile?.addEventListener("click", () => {
      if (popupImageMobile) (popupImageMobile as HTMLInputElement).value = "";
      updatePreview({ popup_mobile_image_url: null });
      clearImageMobile.classList.add("hidden");
      localStorage.removeItem('popupImageMobile');
      const del = document.getElementById("delete_popupImageMobile") as HTMLInputElement;
      if (del) del.value = "1";
  });

  popupImageMobile2?.addEventListener("change", function() {
      handleImageUpload(this, (url) => {
          updatePreview({ popup_mobile_image2_url: url });
          clearImageMobile2?.classList.remove("hidden");
          localStorage.setItem('popupImageMobile2', url);
          const del = document.getElementById("delete_popupImageMobile2") as HTMLInputElement;
          if (del) del.value = "0";
      });
  });
  clearImageMobile2?.addEventListener("click", () => {
      if (popupImageMobile2) (popupImageMobile2 as HTMLInputElement).value = "";
      updatePreview({ popup_mobile_image2_url: null });
      clearImageMobile2.classList.add("hidden");
      localStorage.removeItem('popupImageMobile2');
      const del = document.getElementById("delete_popupImageMobile2") as HTMLInputElement;
      if (del) del.value = "1";
  });

  whatsappImage?.addEventListener("change", function() {
      handleImageUpload(this, (url) => {
          const previewWAImg = document.getElementById("previewWhatsappProfileImg");
          if (previewWAImg) previewWAImg.innerHTML = `<img src="${url}" class="w-full h-full object-cover">`;
          document.getElementById("clearWhatsappImage")?.classList.remove("hidden");
      });
  });

  // LOAD SETTINGS FROM API
  async function loadSettings() {
    setStatus("Cargando...", "loading");
    try {
      const settings = await getPopupSettings();
      if (settings) {
        if (btnBgColorInput) btnBgColorInput.value = settings.button_bg_color || "#14b8a6";
        if (btnTextColorInput) btnTextColorInput.value = settings.button_text_color || "#ffffff";
        if (popupInicioDelayInput) popupInicioDelayInput.value = String(settings.popup_start_delay_minutes || 1);
        
        // Initial Preview update
        updatePreview({
          button_bg_color: settings.button_bg_color,
          button_text_color: settings.button_text_color,
          popup_start_delay_minutes: settings.popup_start_delay_minutes
        });
      }
      
      const savedImage1 = localStorage.getItem('popupImage');
      const savedImage2 = localStorage.getItem('popupImage2');
      const savedImageMobile = localStorage.getItem('popupImageMobile');
      const savedImageMobile2 = localStorage.getItem('popupImageMobile2');
      const savedBgColor = localStorage.getItem('popupBtnBgColor');
      const savedTextColor = localStorage.getItem('popupBtnTextColor');
      const savedDelay = localStorage.getItem('popupDelay');

      if (savedImage1) {
        updatePreview({ popup_image_url: savedImage1 });
        clearImage1?.classList.remove("hidden");
      }
      if (savedImage2) {
        updatePreview({ popup_image2_url: savedImage2 });
        clearImage2?.classList.remove("hidden");
      }
      if (savedImageMobile) {
        updatePreview({ popup_mobile_image_url: savedImageMobile });
        clearImageMobile?.classList.remove("hidden");
      }
      if (savedImageMobile2) {
        updatePreview({ popup_mobile_image2_url: savedImageMobile2 });
        clearImageMobile2?.classList.remove("hidden");
      }
      if (savedBgColor && btnBgColorInput) {
        (btnBgColorInput as HTMLInputElement).value = savedBgColor;
        updatePreview({ button_bg_color: savedBgColor });
      }
      if (savedTextColor && btnTextColorInput) {
        (btnTextColorInput as HTMLInputElement).value = savedTextColor;
        updatePreview({ button_text_color: savedTextColor });
      }
      if (savedDelay && popupInicioDelayInput) {
        (popupInicioDelayInput as HTMLSelectElement).value = savedDelay;
        updatePreview({ popup_start_delay_minutes: parseInt(savedDelay) });
      }
      
      setStatus("Configuración cargada.", "idle");
    } catch (err) {
      console.error(err);
      setStatus("Error al cargar configuración.", "error");
    }
  }

  loadSettings();

  // SAVE SETTINGS
  const btnGuardarPopups = document.getElementById("btnGuardarPopups");
  btnGuardarPopups?.addEventListener("click", async () => {
      const originalText = btnGuardarPopups.innerText;
      btnGuardarPopups.innerText = "Guardando...";
      btnGuardarPopups.disabled = true;
      setStatus("Guardando cambios...", "loading");

      try {
          // Primero guardamos los ajustes JSON (colores y tiempo)
          const bgColor = btnBgColorInput?.value || "#14b8a6";
          const textColor = btnTextColorInput?.value || "#ffffff";
          const delay = parseInt(popupInicioDelayInput?.value || "1");

          if (!isHexColor(bgColor) || !isHexColor(textColor)) {
              throw new Error("Colores no válidos.");
          }

          await updatePopupSettings({
              button_bg_color: bgColor,
              button_text_color: textColor,
              popup_start_delay_minutes: delay
          });

          // Aquí iría la lógica de subida de imágenes si el backend lo soporta vía FormData
          // Por ahora simulamos éxito en el guardado de imágenes
          
          setStatus("¡Guardado exitosamente!", "success");
          setTimeout(() => setStatus(""), 3000);
      } catch (error) {
          console.error(error);
          setStatus("Error al guardar: " + error.message, "error");
      } finally {
          btnGuardarPopups.innerText = originalText;
          btnGuardarPopups.disabled = false;
      }
  });
}

document.addEventListener("DOMContentLoaded", initTabs);
document.addEventListener("astro:page-load", initTabs);
</script>