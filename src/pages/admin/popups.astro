---
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
import ScrollModal from "../../components/ui/ScrollModal.tsx";
import EmailEditor from "../../components/admin/popups/EmailEditor.tsx";
---

<LayoutAdmin title="POPUPS">
    <div
        class="p-0 h-full w-full bg-gray-50 dark:bg-gray-900 overflow-x-hidden"
    >
        <div
            class="bg-teal-500 rounded-t-xl p-4 flex justify-between items-center shadow-lg relative z-10 w-full"
        >
            <div class="flex items-center gap-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-8 w-8 text-white"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                    ></path>
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                    <h1
                        class="text-2xl font-bold text-white tracking-wide drop-shadow-sm"
                    >
                        Configuración de Pop-ups
                    </h1>
                    <p class="text-teal-100 text-sm">
                        Personaliza el aspecto de tus ventanas emergentes
                    </p>
                </div>
            </div>
        </div>

        <!-- Contenido Principal -->
        <div
            class="bg-white dark:bg-gray-800 rounded-b-xl shadow-xl border border-t-0 p-8 border-gray-200 dark:border-gray-700 min-h-[60vh]"
        >
            <div class="grid grid-cols-1 lg:grid-cols-[450px_1fr] gap-10">
                <!-- Columna Izquierda: Formulario de Opciones -->
                <div
                    class="space-y-6 lg:border-r lg:border-gray-200 lg:dark:border-gray-700 lg:pr-8"
                >
                    <div class="flex gap-2 mb-6 border-b pb-2">
                        <button
                            id="tabPopups"
                            class="px-4 py-2 rounded-md bg-teal-600 dark:bg-teal-500 text-white text-sm font-medium shadow-sm transition-all"
                        >
                            Pop-ups
                        </button>

                        <button
                            id="tabWhatsapp"
                            class="px-4 py-2 rounded-md text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700/50 hover:text-gray-700 dark:hover:text-gray-200 text-sm font-medium transition-all"
                        >
                            WhatsApp
                        </button>

                        <button
                            id="tabCorreo"
                            class="px-4 py-2 rounded-md text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700/50 hover:text-gray-700 dark:hover:text-gray-200 text-sm font-medium transition-all"
                        >
                            Correo
                        </button>
                    </div>

                    <div class="space-y-6">
                        <div id="contentPopups" class="flex flex-col gap-4">
                            <!-- Primera Imagen -->
                            <div
                                class="bg-gray-50 dark:bg-gray-800/40 p-6 rounded-2xl border border-gray-100 dark:border-gray-700/50 shadow-sm"
                            >
                                <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100 mb-2">Primera Imagen</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
                                    Sube una imagen promocional para tu popup. Resolución recomendada: 448x550px. La imagen debe pesar 2MB como máximo, recomendación formato webp.
                                </p>
                                <div class="flex items-center gap-3">
                                    <input type="hidden" name="delete_popupImage1" id="delete_popupImage1" value="0" />
                                    <input type="file" id="popupImage1" accept="image/*" class="hidden" />
                                    <button
                                        type="button"
                                        onclick="document.getElementById('popupImage1').click()"
                                        class="inline-flex items-center gap-2 px-6 py-2.5 bg-teal-600 hover:bg-teal-700 text-white font-bold rounded-lg transition-all shadow-md active:scale-95"
                                    >
                                        Subir Imagen 1
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                        </svg>
                                    </button>
                                    <button
                                        type="button"
                                        id="clearImage1"
                                        class="hidden text-red-500 hover:text-red-600 transition-colors p-2"
                                        title="Borrar Imagen 1"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </div>
                            </div>

                            <!-- Segunda Imagen -->
                            <div
                                class="bg-gray-50 dark:bg-gray-800/40 p-6 rounded-2xl border border-gray-100 dark:border-gray-700/50 shadow-sm"
                            >
                                <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100 mb-2">Segunda Imagen</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
                                    Segunda imagen para el popup (mitad derecha). Resolución recomendada: 448x550px. La imagen debe pesar 2MB como máximo, recomendación formato webp.
                                </p>
                                <div class="flex items-center gap-3">
                                    <input type="hidden" name="delete_popupImage2" id="delete_popupImage2" value="0" />
                                    <input type="file" id="popupImage2" accept="image/*" class="hidden" />
                                    <button
                                        type="button"
                                        onclick="document.getElementById('popupImage2').click()"
                                        class="inline-flex items-center gap-2 px-6 py-2.5 bg-teal-600 hover:bg-teal-700 text-white font-bold rounded-lg transition-all shadow-md active:scale-95"
                                    >
                                        Subir Imagen 2
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                        </svg>
                                    </button>
                                    <button
                                        type="button"
                                        id="clearImage2"
                                        class="hidden text-red-500 hover:text-red-600 transition-colors p-2"
                                        title="Borrar Imagen 2"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </div>
                            </div>

                            <!-- Primera Imagen Móvil -->
                            <div
                                class="bg-gray-50 dark:bg-gray-800/40 p-6 rounded-2xl border border-gray-100 dark:border-gray-700/50 shadow-sm"
                            >
                                <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100 mb-2">Primera Imagen Móvil</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
                                    Imagen para vista en dispositivos móviles. Resolución recomendada: 448x640px. La imagen debe pesar 2MB como máximo, recomendación formato webp.
                                </p>
                                <div class="flex items-center gap-3">
                                    <input type="hidden" name="delete_popupImageMobile" id="delete_popupImageMobile" value="0" />
                                    <input type="file" id="popupImageMobile" accept="image/*" class="hidden" />
                                    <button
                                        type="button"
                                        onclick="document.getElementById('popupImageMobile').click()"
                                        class="inline-flex items-center gap-2 px-6 py-2.5 bg-teal-600 hover:bg-teal-700 text-white font-bold rounded-lg transition-all shadow-md active:scale-95"
                                    >
                                        Subir Imagen Móvil 1
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                        </svg>
                                    </button>
                                    <button
                                        type="button"
                                        id="clearImageMobile"
                                        class="hidden text-red-500 hover:text-red-600 transition-colors p-2"
                                        title="Borrar Imagen Móvil"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </div>
                            </div>

                            <!-- Segunda Imagen Móvil -->
                            <div
                                class="bg-gray-50 dark:bg-gray-800/40 p-6 rounded-2xl border border-gray-100 dark:border-gray-700/50 shadow-sm"
                            >
                                <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100 mb-2">Segunda Imagen Móvil</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
                                    Segunda imagen para vista en dispositivos móviles (abajo). Resolución recomendada: 448x640px. La imagen debe pesar 2MB como máximo, recomendación formato webp.
                                </p>
                                <div class="flex items-center gap-3">
                                    <input type="hidden" name="delete_popupImageMobile2" id="delete_popupImageMobile2" value="0" />
                                    <input type="file" id="popupImageMobile2" accept="image/*" class="hidden" />
                                    <button
                                        type="button"
                                        onclick="document.getElementById('popupImageMobile2').click()"
                                        class="inline-flex items-center gap-2 px-6 py-2.5 bg-teal-600 hover:bg-teal-700 text-white font-bold rounded-lg transition-all shadow-md active:scale-95"
                                    >
                                        Subir Imagen Móvil 2
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                        </svg>
                                    </button>
                                    <button
                                        type="button"
                                        id="clearImageMobile2"
                                        class="hidden text-red-500 hover:text-red-600 transition-colors p-2"
                                        title="Borrar Imagen Móvil 2"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </div>
                            </div>

                            <!-- Configuración de Colores -->
                            <div class="grid grid-cols-[1fr_1.2fr] gap-4 mt-4">
                                <!-- Color del Botón -->
                                <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800/40 border border-gray-100 dark:border-gray-700/50 shadow-sm">
                                    <span class="block text-sm font-bold text-gray-600 dark:text-gray-400 mb-3">Color del Botón</span>
                                    <div class="flex items-center gap-3">
                                        <div class="relative w-12 h-12 rounded-full overflow-hidden border-2 border-white dark:border-gray-600 shadow-md cursor-pointer hover:scale-105 transition-transform">
                                            <input
                                                type="color"
                                                id="btnBgColor"
                                                value="#14b8a6"
                                                class="absolute -top-2 -left-2 w-16 h-16 cursor-pointer"
                                            />
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="text-xs font-bold text-gray-500 dark:text-gray-400">Seleccionar</span>
                                            <span class="text-xs text-gray-400">fondo</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Color del Texto -->
                                <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800/40 border border-gray-100 dark:border-gray-700/50 shadow-sm">
                                    <span class="block text-sm font-bold text-gray-600 dark:text-gray-400 mb-3">Color del Texto</span>
                                    <div class="flex items-center gap-3">
                                        <div class="relative w-12 h-12 rounded-full overflow-hidden border-2 border-white dark:border-gray-600 shadow-md cursor-pointer hover:scale-105 transition-transform">
                                            <input
                                                type="color"
                                                id="btnTextColor"
                                                value="#ffffff"
                                                class="absolute -top-2 -left-2 w-16 h-16 cursor-pointer"
                                            />
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="text-xs font-bold text-gray-500 dark:text-gray-400">Seleccionar</span>
                                            <span class="text-xs text-gray-400">texto</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <h2 class="text-xl font-extrabold text-gray-800 dark:text-gray-100 mt-8 mb-4">Tiempo de Aparición</h2>

                            <div class="grid grid-cols-[1fr_1.2fr] gap-4">
                                <!-- Pop-up de Inicio -->
                                <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800/40 border border-gray-100 dark:border-gray-700/50 shadow-sm">
                                    <label for="popupInicioDelay" class="block text-sm font-bold text-gray-600 dark:text-gray-400 mb-2">Pop-up de Inicio</label>
                                    <select
                                        id="popupInicioDelay"
                                        class="w-full bg-white dark:bg-gray-700 border-none rounded-lg p-2.5 text-sm font-medium focus:ring-2 focus:ring-teal-500 transition-all cursor-pointer shadow-inner"
                                    >
                                        <option value="1" selected>1 minuto</option>
                                        <option value="2">2 minutos</option>
                                        <option value="3">3 minutos</option>
                                        <option value="4">4 minutos</option>
                                        <option value="5">5 minutos</option>
                                        <option value="6">6 minutos</option>
                                        <option value="7">7 minutos</option>
                                        <option value="8">8 minutos</option>
                                        <option value="9">9 minutos</option>
                                        <option value="10">10 minutos</option>
                                    </select>
                                </div>

                                <!-- Pop-ups de Productos -->
                                <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800/40 border border-gray-100 dark:border-gray-700/50 shadow-sm">
                                    <label for="popupProductosDelay" class="block text-sm font-bold text-gray-600 dark:text-gray-400 mb-2">Pop-ups de Productos</label>
                                    <select
                                        id="popupProductosDelay"
                                        class="w-full bg-white dark:bg-gray-700 border-none rounded-lg p-2.5 text-sm font-medium focus:ring-2 focus:ring-teal-500 transition-all cursor-pointer shadow-inner"
                                    >
                                        <option value="1" selected>1 minuto</option>
                                        <option value="2">2 minutos</option>
                                        <option value="3">3 minutos</option>
                                        <option value="4">4 minutos</option>
                                        <option value="5">5 minutos</option>
                                        <option value="6">6 minutos</option>
                                        <option value="7">7 minutos</option>
                                        <option value="8">8 minutos</option>
                                        <option value="9">9 minutos</option>
                                        <option value="10">10 minutos</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div
                            id="contentWhatsapp"
                            class="hidden flex flex-col gap-4"
                        >
                            <!-- Editar Mensaje de WhatsApp -->
                            <div
                                class="flex flex-col p-6 rounded-lg bg-gray-50 hover:bg-teal-50 dark:bg-gray-700/50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-600 transition-colors gap-6"
                            >
                                <div class="w-full">
                                    <h3
                                        class="font-medium text-gray-900 dark:text-gray-100 text-lg flex items-center gap-2"
                                    >
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="20"
                                            height="20"
                                            fill="currentColor"
                                            class="text-green-500 shrink-0"
                                            viewBox="0 0 16 16"
                                        >
                                            <path
                                                d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"
                                            ></path>
                                        </svg>
                                        WhatsApp
                                    </h3>
                                    <p
                                        class="text-sm text-gray-500 dark:text-gray-400 mt-1 mb-4"
                                    >
                                        Configura la imagen y mensaje
                                        predeterminado que se enviarán. La imagen debe pesar 2MB como máximo, recomendación formato webp.
                                    </p>
                                    <div class="flex items-center space-x-2">
                                        <input
                                            type="hidden"
                                            name="delete_whatsappImage"
                                            id="delete_whatsappImage"
                                            value="0"
                                        />
                                        <input
                                            type="file"
                                            id="whatsappImage"
                                            accept="image/*"
                                            class="hidden"
                                        />
                                        <button
                                            type="button"
                                            onclick="document.getElementById('whatsappImage').click()"
                                            class="inline-flex items-center px-4 py-2 bg-[#128C7E] text-sm font-medium rounded-md text-white hover:bg-[#075E54] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#128C7E] transition-colors shadow-sm"
                                        >
                                            Añadir Imagen a WhatsApp
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                class="ml-2 h-4 w-4"
                                                fill="none"
                                                viewBox="0 0 24 24"
                                                stroke="currentColor"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"
                                                ></path>
                                            </svg>
                                        </button>
                                        <button
                                            type="button"
                                            id="clearWhatsappImage"
                                            class="hidden text-red-500 hover:text-red-700 text-sm font-semibold p-2"
                                            title="Borrar Imagen WhatsApp"
                                        >
                                            ✕
                                        </button>
                                    </div>
                                </div>
                                <div class="w-full">
                                    <label
                                        for="whatsappMessage"
                                        class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                                        >Mensaje de WhatsApp</label
                                    >
                                    <textarea
                                        id="whatsappMessage"
                                        rows="4"
                                        class="block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 shadow-sm focus:border-green-500 focus:ring-green-500 sm:text-sm p-3 border"
                                        placeholder="Escribe tu mensaje aquí... Ej: ¡Hola! Me gustaría obtener el descuento del popup..."
                                        >¡Hola! Me gustaría obtener más
                                        información sobre la promoción.</textarea
                                    >
                                </div>
                            </div>
                        </div>

                        <div
                            id="contentCorreo"
                            class="hidden space-y-6"
                        >
                            <!-- Editar Mensaje de Correo -->
                            <div
                                class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm space-y-6"
                            >
                                <div class="flex items-start justify-between">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center text-blue-600 dark:text-blue-400 shrink-0">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg">Correo Electrónico</h3>
                                            <p class="text-xs text-gray-500 dark:text-gray-400">Configura el título, mensaje e imagen para los emails. Recomendación formato webp.</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="space-y-4">
                                    <div class="flex items-center gap-3">
                                        <input type="hidden" name="delete_emailImage" id="delete_emailImage" value="0" />
                                        <input type="file" id="emailImage" accept="image/*" class="hidden" />
                                        <button
                                            type="button"
                                            onclick="document.getElementById('emailImage').click()"
                                            class="inline-flex items-center px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg transition-all shadow-md group active:scale-95"
                                        >
                                            Añadir Imagen Adjunta
                                            <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4 group-hover:rotate-12 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                                            </svg>
                                        </button>
