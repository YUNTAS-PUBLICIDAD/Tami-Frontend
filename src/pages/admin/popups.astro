<script>
function initTabs() {
  const tabPopups = document.getElementById("tabPopups");
  const tabWhatsapp = document.getElementById("tabWhatsapp");
  const tabCorreo = document.getElementById("tabCorreo");

  const contentPopups = document.getElementById("contentPopups");
  const contentWhatsapp = document.getElementById("contentWhatsapp");
  const contentCorreo = document.getElementById("contentCorreo");

  // PREVIEWS
  const previewPopups = document.getElementById("previewPopups");
  const previewPopupsContainer = document.getElementById("previewContainer");
  const previewWhatsapp = document.getElementById("previewWhatsapp");
  const previewCorreo = document.getElementById("previewCorreo");
  const previewOverlay = document.getElementById("previewOverlay");
  const previewModesToggle = document.getElementById("previewModesToggle");
  const previewStage = document.getElementById("previewStage");

  if (!tabPopups || !tabWhatsapp || !tabCorreo) {
    setTimeout(initTabs, 200);
    return;
  }

  const tabs = [tabPopups, tabWhatsapp, tabCorreo];
  const contents = [contentPopups, contentWhatsapp, contentCorreo];

  function activarTab(tab, content, previewActivo) {
    // Desactivar todos
    tabs.forEach(t => {
        t.classList.remove("bg-teal-600", "text-white", "dark:bg-teal-500", "bg-teal-500");
        t.classList.add("text-gray-500", "dark:text-gray-400", "hover:text-gray-700", "dark:hover:text-gray-200");
    });
    
    contents.forEach(c => c.classList.add("hidden"));
    
    // Ocultar todas las vistas previas
    previewPopupsContainer.classList.add("hidden");
    previewWhatsapp.classList.add("hidden");
    previewCorreo.classList.add("hidden");

    // Activar seleccionados
    tab.classList.remove("text-gray-500", "dark:text-gray-400", "hover:text-gray-700", "dark:hover:text-gray-200");
    tab.classList.add("bg-teal-600", "text-white", "dark:bg-teal-500");
    content.classList.remove("hidden");

    // Manejo de la vista previa específica
    previewActivo.classList.remove("hidden");
    
    // Toggle "Full Stage" mode for Gmail
    if (previewActivo === previewCorreo) {
        if (previewStage) previewStage.classList.add("is-gmail");
    } else {
        if (previewStage) previewStage.classList.remove("is-gmail");
    }

    if (previewActivo === previewPopupsContainer) {
        if (previewOverlay) previewOverlay.classList.remove("hidden");
        if (previewModesToggle) previewModesToggle.classList.remove("hidden");
    } else {
        if (previewOverlay) previewOverlay.classList.add("hidden");
        if (previewModesToggle) previewModesToggle.classList.add("hidden");
    }
  }

  // EVENTOS TABS
  tabPopups.onclick = () => activarTab(tabPopups, contentPopups, previewPopupsContainer);
  tabWhatsapp.onclick = () => activarTab(tabWhatsapp, contentWhatsapp, previewWhatsapp);
  tabCorreo.onclick = () => activarTab(tabCorreo, contentCorreo, previewCorreo);

  // ESTADO INICIAL
  activarTab(tabPopups, contentPopups, previewPopupsContainer);

  // WHATSAPP PREVIEW SYNC
  const textareaWhatsapp = document.getElementById("whatsappMessage");
  const previewWhatsappText = document.getElementById("previewWhatsappText");
  if (textareaWhatsapp && previewWhatsappText) {
    textareaWhatsapp.addEventListener("input", () => {
      previewWhatsappText.textContent = textareaWhatsapp.value;
    });
  }

  // CORREO PREVIEW SYNC
  const emailTitle = document.getElementById("emailTitle");
  const emailBody = document.getElementById("emailBody");
  const previewCorreoTitle = document.getElementById("previewCorreoTitle");
  const previewCorreoBody = document.getElementById("previewCorreoBody");

  if (emailTitle && previewCorreoTitle) {
    emailTitle.addEventListener("input", () => {
      previewCorreoTitle.textContent = emailTitle.value;
    });
  }
  if (emailBody && previewCorreoBody) {
    emailBody.addEventListener("input", () => {
      previewCorreoBody.textContent = emailBody.value;
    });
  }

  // PREVIEW MODES (Escritorio / Móvil)
  const btnDesktop = document.getElementById("btnDesktop");
  const btnMobile = document.getElementById("btnMobile");
  const previewContainer = document.getElementById("previewContainer");

  if (btnDesktop && btnMobile && previewContainer && previewPopups) {
      function activeMode(modo) {
          previewContainer.setAttribute("data-mode", modo);
          previewPopups.setAttribute("data-mode", modo);
          if (modo === "desktop") {
              btnDesktop.classList.add("bg-white", "dark:bg-gray-700", "text-teal-600", "shadow-sm");
              btnDesktop.classList.remove("text-gray-500", "dark:text-gray-400");
              btnMobile.classList.remove("bg-white", "dark:bg-gray-700", "text-teal-600", "shadow-sm");
              btnMobile.classList.add("text-gray-500", "dark:text-gray-400");
          } else {
              btnMobile.classList.add("bg-white", "dark:bg-gray-700", "text-teal-600", "shadow-sm");
              btnMobile.classList.remove("text-gray-500", "dark:text-gray-400");
              btnDesktop.classList.remove("bg-white", "dark:bg-gray-700", "text-teal-600", "shadow-sm");
              btnDesktop.classList.add("text-gray-500", "dark:text-gray-400");
          }
      }
      btnDesktop.onclick = () => activeMode("desktop");
      btnMobile.onclick = () => activeMode("mobile");
  }
}

// INICIAR
initTabs();
</script>