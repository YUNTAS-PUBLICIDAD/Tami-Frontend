<script>
  
      const initPopupSettings = () => {
        console.log("SCRIPT FUNCIONANDO");
                const btnTextColorInput = document.getElementById('btnTextColor');
                const btnBgColorInput = document.getElementById('btnBgColor');
                    const previewButton = document.getElementById('previewButton');

          if (
            btnTextColorInput instanceof HTMLInputElement &&
            btnBgColorInput instanceof HTMLInputElement &&
            previewButton instanceof HTMLButtonElement
          ) {
              previewButton.style.color = btnTextColorInput.value;
              previewButton.style.backgroundColor = btnBgColorInput.value;

              btnTextColorInput.oninput = () => {
                  previewButton.style.color = btnTextColorInput.value;
              };

              btnBgColorInput.oninput = () => {
                  previewButton.style.backgroundColor = btnBgColorInput.value;
              };
          }

          const btnDesktop = document.getElementById('btnDesktop');
          const btnMobile = document.getElementById('btnMobile');
          const previewContainer = document.getElementById('previewContainer');

          if (btnDesktop && btnMobile && previewContainer) {
              const activeBtnClasses = ['bg-white', 'dark:bg-gray-700', 'text-teal-600', 'shadow-sm'];
              const inactiveBtnClasses = ['text-gray-500', 'hover:text-gray-700', 'dark:text-gray-400', 'dark:hover:text-gray-200'];

              btnDesktop.onclick = () => {
                  // Button styles
                  btnDesktop.classList.add(...activeBtnClasses);
                  btnDesktop.classList.remove(...inactiveBtnClasses);
                  btnMobile.classList.remove(...activeBtnClasses);
                  btnMobile.classList.add(...inactiveBtnClasses);

                  // Switch to Desktop Data attribute
                  previewContainer.setAttribute('data-mode', 'desktop');
              };

              btnMobile.onclick = () => {
                  // Button styles
                  btnMobile.classList.add(...activeBtnClasses);
                  btnMobile.classList.remove(...inactiveBtnClasses);
                  btnDesktop.classList.remove(...activeBtnClasses);
                  btnDesktop.classList.add(...inactiveBtnClasses);

                  // Switch to Mobile Data attribute
                  previewContainer.setAttribute('data-mode', 'mobile');
              };
          }
      };

// Iniciar el script
document.addEventListener("DOMContentLoaded", initPopupSettings);
document.addEventListener("astro:page-load", initPopupSettings);

  </script>
</LayoutAdmin>

<script>
    import { getPopupSettings, updatePopupSettings, isHexColor } from "../../lib/api/popupSettings";

    const DEFAULT_BUTTON_BG = "#14B8A6";
    const DEFAULT_BUTTON_TEXT = "#FFFFFF";

    const btnBgColor = document.querySelector("#btnBgColor");
    const btnTextColor = document.querySelector("#btnTextColor");
    const btnBgColorInput = document.querySelector("#btnBgColorInput");
    const btnTextColorInput = document.querySelector("#btnTextColorInput");
    const previewButton = document.querySelector("#previewButton");
    const saveButton = document.querySelector("#savePopupSettingsBtn");
    const statusElement = document.querySelector("#popupStatus");

    if (
        !(btnBgColor instanceof HTMLInputElement) ||
        !(btnTextColor instanceof HTMLInputElement) ||
        !(btnBgColorInput instanceof HTMLInputElement) ||
        !(btnTextColorInput instanceof HTMLInputElement) ||
        !(saveButton instanceof HTMLButtonElement) ||
        !(statusElement instanceof HTMLParagraphElement)
    ) {
        throw new Error("No se pudo inicializar el formulario de popup settings.");
    }

    const normalizeHex = (value: string): string => value.trim().toUpperCase();

    const setStatus = (
        message: string,
        type: "idle" | "loading" | "saving" | "success" | "error" = "idle",
    ): void => {
        statusElement.textContent = message;
        statusElement.classList.remove(
            "text-gray-600",
            "text-gray-300",
            "text-teal-600",
            "text-red-500",
            "text-amber-500",
        );

        if (type === "success") {
            statusElement.classList.add("text-teal-600");
            return;
        }

        if (type === "error") {
            statusElement.classList.add("text-red-500");
            return;
        }

        if (type === "loading" || type === "saving") {
            statusElement.classList.add("text-amber-500");
            return;
        }

        statusElement.classList.add("text-gray-600", "dark:text-gray-300");
    };

    const setEditableControlsDisabled = (disabled: boolean): void => {
        btnBgColor.disabled = disabled;
        btnTextColor.disabled = disabled;
        btnBgColorInput.disabled = disabled;
        btnTextColorInput.disabled = disabled;
        saveButton.disabled = disabled;
    };

    const applyColorsToForm = (buttonBgColor: string, buttonTextColor: string): void => {
        const normalizedBg = normalizeHex(buttonBgColor);
        const normalizedText = normalizeHex(buttonTextColor);

        btnBgColor.value = normalizedBg;
        btnBgColorInput.value = normalizedBg;

        btnTextColor.value = normalizedText;
        btnTextColorInput.value = normalizedText;

        if (previewButton instanceof HTMLButtonElement) {
            previewButton.style.backgroundColor = normalizedBg;
            previewButton.style.color = normalizedText;
        }
    };

    const mapHttpError = (error: unknown): string => {
        const typedError = error as { response?: { status?: number } };
        const status = typedError?.response?.status;

        if (status === 401 || status === 403) {
            return "No tienes sesión activa o permisos para modificar esta configuración.";
        }

        if (status === 422) {
            return "El backend rechazó los datos. Verifica los colores ingresados.";
        }

        if (status === 500) {
            return "Ocurrió un error interno del servidor. Intenta nuevamente.";
        }

        return "No fue posible guardar la configuración de popup.";
    };

    const syncTextFromColorPicker = (colorInput: HTMLInputElement, textInput: HTMLInputElement): void => {
        textInput.value = normalizeHex(colorInput.value);
    };

    const syncColorPickerFromText = (textInput: HTMLInputElement, colorInput: HTMLInputElement): void => {
        const normalized = normalizeHex(textInput.value);
        textInput.value = normalized;

        if (isHexColor(normalized)) {
            colorInput.value = normalized;
        }
    };

    btnBgColor.addEventListener("input", () => syncTextFromColorPicker(btnBgColor, btnBgColorInput));
    btnTextColor.addEventListener("input", () => syncTextFromColorPicker(btnTextColor, btnTextColorInput));
    btnBgColorInput.addEventListener("blur", () => syncColorPickerFromText(btnBgColorInput, btnBgColor));
    btnTextColorInput.addEventListener("blur", () => syncColorPickerFromText(btnTextColorInput, btnTextColor));

    const loadSettings = async () => {
        setEditableControlsDisabled(true);
        setStatus("Cargando configuración...", "loading");

        try {
            const settings = await getPopupSettings();
            const bgColor = normalizeHex(settings?.button_bg_color || DEFAULT_BUTTON_BG);
            const textColor = normalizeHex(settings?.button_text_color || DEFAULT_BUTTON_TEXT);

            applyColorsToForm(bgColor, textColor);
            setStatus("Configuración cargada correctamente.", "idle");
        } catch (error) {
            applyColorsToForm(DEFAULT_BUTTON_BG, DEFAULT_BUTTON_TEXT);
            setStatus(mapHttpError(error), "error");
        } finally {
            setEditableControlsDisabled(false);
        }
    };

    saveButton.addEventListener("click", async () => {
        const buttonBgColor = normalizeHex(btnBgColorInput.value);
        const buttonTextColor = normalizeHex(btnTextColorInput.value);

        if (!isHexColor(buttonBgColor) || !isHexColor(buttonTextColor)) {
            setStatus("Los colores deben tener el formato exacto #RRGGBB.", "error");
            return;
        }

        setEditableControlsDisabled(true);
        saveButton.textContent = "Guardando...";
        setStatus("Guardando cambios...", "saving");

        try {
            const updatedSettings = await updatePopupSettings({
                button_bg_color: buttonBgColor,
                button_text_color: buttonTextColor,
            });

            applyColorsToForm(updatedSettings.button_bg_color, updatedSettings.button_text_color);
            setStatus("Cambios guardados exitosamente.", "success");
        } catch (error) {
            setStatus(mapHttpError(error), "error");
        } finally {
            saveButton.textContent = "Guardar Cambios";
            setEditableControlsDisabled(false);
        }
    });

    loadSettings();
</script>
