---
import Layout from "src/layouts/Layout.astro";
import { config } from "config";
import { showLoaderString, removeLoaderString } from "src/utils/loader";
import blogHeroImage from "@images/index/hero/impulso-negocios-tecnologia.webp";

const getApiUrl = config.apiUrl
  ? String(config.apiUrl).replace(/\/+$/, "")
  : "";
const blogsUrl = config.endpoints.blogs;

const productsUrl = config.endpoints.productos.list;
---

<Layout
  title="Blog Details"
  description="Descripcion por defecto"
  canonicalUrl="https://tamimaquinarias.com/blog"
>
  <header
    id="blog-header"
    class="relative w-full h-[30vh] sm:h-screen min-h-[200px] flex items-center justify-center overflow-hidden pt-16 sm:pt-20"
  >
    <img
      id="blog-img"
      src="/fallback.webp"
      width={blogHeroImage.width}
      height={blogHeroImage.height}
      alt="Fondo Hero"
      title="Fondo Hero"
      class="absolute inset-0 w-full h-full object-cover brightness-[0.45]"
    />

    <!-- Overlay -->
    <div
      class="z-10 relative w-full h-full flex flex-col items-center justify-center text-white px-3 sm:px-8 py-2 sm:py-8 text-center"
    >
      <div class="max-w-5xl mx-auto font-bold w-full">
        <h1
          id="blog-title"
          class="font-montserrat tracking-tight leading-snug drop-shadow-lg break-words"
          style="font-size: clamp(0.85rem, 3.5vw + 0.5rem, 3.75rem); line-height: 1.2;"
        >
        </h1>
      </div>
    </div>
  </header>
  <style>
    #blog-img {
      animation: panHorizontal 10s ease-in-out infinite alternate;
      transform-origin: center;
      will-change: transform;
    }

    @keyframes panHorizontal {
      0% {
        transform: scale(1.1) translateX(3%);
      }
      100% {
        transform: scale(1.1) translateX(-3%);
      }
    }
  </style>
  <main
    class="py-8 md:py-20 px-4 md:px-20 bg-gradient-to-b from-[#041019] to-[#003E56]"
  >
    <!-- CONTENIDO PRINCIPAL -->
    <div
      id="blog-content"
      class="mx-auto px-4 md:px-8 py-6 md:py-10 bg-white rounded-xl md:rounded-2xl shadow-lg md:shadow-xl mb-8 md:mb-16 border border-gray-200"
    >
      <!-- Espacio adicional entre título y contenido -->
      <div class="mb-8 md:mb-12">
        <div class="mb-6 md:mb-10">
          <h2
            id="blog-content-subtitle"
            class="text-lg lg:text-2xl
           font-bold lg:font-semibold font-garet
           text-sky-300
           mb-3 text-center break-words"
          >
          </h2>
          <p
            id="blog-content-subtitle2"
            class="px-2 md:px-8 text-base md:text-xl font-semibold text-black text-center md:text-left break-words"
          >
          </p>
        </div>

        <!-- Fecha -->
        <div
          id="blog-date"
          class="inline-block px-4 md:px-6 py-2 bg-[#00B6FF] text-white text-sm md:text-base font-semibold rounded-full mb-8 md:mb-12 text-center shadow-md mx-auto block w-fit"
        >
          Fecha de publicación no disponible
        </div>

        <!-- Contenido principal -->
        <div id="blog-sections" class="space-y-8 md:space-y-16">
          <!-- Secciones dinámicas -->
        </div>

        <!-- BOTÓN VER PRODUCTO -->
        <div class="flex justify-center mb-8 md:mb-12">
          <a
            id="btn-ver-producto"
            href="#"
            class="hidden bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-8 rounded-lg shadow-lg transition-all duration-300 transform hover:scale-105"
          >
            Ver Producto
          </a>
        </div>
      </div>

      <!-- VIDEO -->
      <div
        id="blog-video-container"
        class="hidden mx-auto px-4 md:px-20 py-4 md:py-6 bg-white rounded-xl md:rounded-2xl shadow-lg md:shadow-xl mb-8 md:mb-10 border border-gray-200"
      >
        <div id="blog-video-section" class="mt-4 md:mt-8"></div>
      </div>
    </div>

    <!-- 🔒 SCRIPTS -->
    <script
      define:vars={{
        getApiUrl,
        blogsUrl,
        productsUrl,
        showLoaderString,
        removeLoaderString,
      }}
    >
      eval(showLoaderString);
      eval(removeLoaderString);
      function getBlogImageUrl(imagePath) {
        if (!imagePath) return "";
        if (imagePath.startsWith("http") || imagePath.startsWith("//")) {
          return imagePath;
        }
        const normalizedBase = String(getApiUrl || "").replace(/\/$/, "");
        const normalizedPath = imagePath.startsWith("/")
          ? imagePath
          : `/${imagePath}`;
        return `${normalizedBase}${normalizedPath}`;
      }

      function removeLoaderSafe() {
        try {
          removeLoader();
        } catch (error) {}
        setTimeout(() => {
          const loader = document.getElementById("page-loader");
          if (loader) loader.remove();
        }, 100);
      }
      document.addEventListener("DOMContentLoaded", async () => {
        showLoader();
        const safetyTimeout = setTimeout(removeLoaderSafe, 10000);
        try {
          const params = new URLSearchParams(window.location.search);
          const linkBlog = params
            .get("link")
            ?.trim()
            .replace(/^\/+|\/+$/g, "");
            if (!linkBlog) {
            clearTimeout(safetyTimeout);
            removeLoaderSafe();
            return;
          }
          const encodedLink = encodeURIComponent(linkBlog);
          const fullUrl = `${getApiUrl}${blogsUrl.list}/link/${encodedLink}/`;
          if (!fullUrl.startsWith("http"))
            throw new Error(`URL inválida: ${fullUrl}`);
          const response = await fetch(fullUrl);
          if (!response.ok)
            throw new Error(`HTTP error! status: ${response.status}`);
          const data = await response.json();
          if (!data || !data.data)
            throw new Error("No se encontraron datos del blog");
          const blog = data.data;
          function setDynamicSEO(blog) {
            document.title = blog.etiqueta?.meta_titulo || blog.titulo;
            let metaDescription = document.querySelector(
              'meta[name="description"]',
            );
            if (!metaDescription) {
              metaDescription = document.createElement("meta");
              metaDescription.name = "description";
              document.head.appendChild(metaDescription);
            }
            metaDescription.content =
              blog.etiqueta?.meta_descripcion || "Descripción por defecto";
            let canonicalLink = document.querySelector('link[rel="canonical"]');
            if (!canonicalLink) {
              canonicalLink = document.createElement("link");
              canonicalLink.rel = "canonical";
              document.head.appendChild(canonicalLink);
            }
            canonicalLink.href = window.location.href;
          }

          function generateBlogJsonLd(blog) {
            const images = [
              getBlogImageUrl(blog.miniatura),
              ...(blog.imagenes?.map((img) =>
                getBlogImageUrl(img.ruta_imagen),
              ) || []),
            ];
            const description =
              blog.subtitulo1 || blog.parrafos?.map((p) => p.parrafo).join(" ");
            return {
              "@context": "https://schema.org/",
              "@type": "Blog",
              "@id": "https://tamimaquinarias.com/blog/",
              mainEntityOfPage: "https://tamimaquinarias.com/blog/",
              name: blog.titulo,
              description: description,
              publisher: {
                "@type": "Organization",
                "@id": "https://tamimaquinarias.com",
                name: "Tami Maquinarias",
                logo: {
                  "@type": "ImageObject",
                  "@id":
                    "https://tamimaquinarias.com/_astro/logo-estatico-100x116.B0Pf3Br1.webp",
                  url: "https://tamimaquinarias.com/_astro/logo-estatico-100x116.B0Pf3Br1.webp",
                  width: "600",
                  height: "60",
                },
              },
              blogPost: [
                {
                  "@type": "BlogPosting",
                  "@id": `https://tamimaquinarias.com/blog/${blog.link}/`,
                  mainEntityOfPage: `https://tamimaquinarias.com/blog/${blog.link}/`,
                  headline: blog.nombre_producto,
                  name: blog.nombre_producto,
                  description: description,
                  datePublished: blog.created_at,
                  dateModified: blog.updated_at,
                  author: {
                    "@type": "Person",
                    url: "https://tamimaquinarias.com",
                    name: "Equipo Tami Maquinarias",
                  },
                  image: {
                    "@type": "ImageObject",
                    "@id": images[0],
                    url: images[0],
                    height: "800",
                    width: "1200",
                  },
                  url: `https://tamimaquinarias.com/blog/${blog.link}/`,
                  keywords: ["LED", "Marketing Visual"],
                },
              ],
            };
          }

          function insertJsonLdBlog(blog) {
            const jsonLd = generateBlogJsonLd(blog);
            const script = document.createElement("script");
            script.type = "application/ld+json";
            script.text = JSON.stringify(jsonLd, null, 2);
            document.head.appendChild(script);
          }

          setDynamicSEO(blog);
          insertJsonLdBlog(blog);

          const blogTitleElement = document.getElementById("blog-title");
          const blogTitleMobileElement =
            document.getElementById("blog-title-mobile");
          const blogTitleDesktopElement =
            document.getElementById("blog-title-desktop");
          const blogImgElement = document.getElementById("blog-img");
          const blogDateElement = document.getElementById("blog-date");
          const blogContentSubtitleElement = document.getElementById(
            "blog-content-subtitle",
          );
          const blogContentSubtitle2Element = document.getElementById(
            "blog-content-subtitle2",
          );
          const blogSectionsElement = document.getElementById("blog-sections");
          const blogVideoSectionElement =
            document.getElementById("blog-video-section");
          const blogVideoContainerElement =
            document.getElementById("blog-video-container");
          const titulo = blog.titulo.toUpperCase();
          if (blogImgElement) {
          blogImgElement.src = getBlogImageUrl(blog.hero_image || blog.miniatura || "/images/fallback.webp");
          }

          if (blogTitleElement) blogTitleElement.innerHTML = titulo;
          if (blogTitleMobileElement) blogTitleMobileElement.innerHTML = titulo;
          if (blogTitleDesktopElement)
            blogTitleDesktopElement.innerHTML = titulo;
          if (blogContentSubtitleElement)
            blogContentSubtitleElement.innerHTML =
              blog.subtitulo1.toUpperCase();
          if (blogContentSubtitle2Element)
            blogContentSubtitle2Element.innerHTML = blog.subtitulo2;
          if (blogImgElement) {
          blogImgElement.alt = blog.titulo;
          }

          if (blogDateElement) {
            const dateStr = blog.created_at || blog.updated_at;
            if (dateStr) {
              // Parse manual para evitar desfases por zona horaria
              const parts = dateStr.split(/[- :T]/);
              const year = parts[0];
              const month = parts[1];
              const day = parts[2];
              blogDateElement.innerHTML = `${day}-${month}-${year}`;
            } else {
              blogDateElement.innerHTML = "FECHA DE PUBLICACIÓN";
            }
          }

          const btnVerProducto = document.getElementById("btn-ver-producto");

          if (btnVerProducto && blog.producto_id) {
            let slugProducto = "";

            // Intento 1: Objeto directo
            if (blog.producto && blog.producto.link) {
              slugProducto = blog.producto.link;
            }
            // Intento 2: Propiedad plana
            else if (blog.producto_link) {
              slugProducto = blog.producto_link;
            }
            // Intento 3: Fetch adicional al API de productos
            else {
              try {
                // Usamos productsUrl que pasamos en define:vars
                const prodRes = await fetch(
                  `${getApiUrl}${productsUrl}/${blog.producto_id}`,
                );
                if (prodRes.ok) {
                  const prodData = await prodRes.json();
                  const productoReal = prodData.data || prodData;
                  if (productoReal && productoReal.link) {
                    slugProducto = productoReal.link;
                  }
                }
              } catch (err) {
                console.error("Error buscando el producto relacionado:", err);
              }
            }

            if (slugProducto) {
              btnVerProducto.href = `/catalogo-maquinarias/detalle/?link=${slugProducto}`;
              btnVerProducto.innerText =
                blog.etiqueta?.popup_button_text?.trim() || "Ver Producto";
              if (blog.etiqueta?.popup_button_color) {
                btnVerProducto.style.setProperty(
                  "background-color",
                  blog.etiqueta.popup_button_color,
                  "important",
                );
              }
              if (blog.etiqueta?.popup_text_color) {
                btnVerProducto.style.setProperty(
                  "color",
                  blog.etiqueta.popup_text_color,
                  "important",
                );
              }
              btnVerProducto.classList.remove("hidden");
              btnVerProducto.classList.add("inline-block");
            }
          }

          if (
            blogSectionsElement &&
            Array.isArray(blog.imagenes) &&
            Array.isArray(blog.parrafos)
          ) {
            blogSectionsElement.innerHTML = "";
            blog.imagenes.forEach((imagen, index) => {
              const section = document.createElement("section");
              section.className = "mb-8 md:mb-12";

              section.innerHTML = `
              <!-- Texto primero en mobile, layout lateral en desktop -->
            <div class="flex flex-col min-[930px]:flex-row ${index % 2 === 1 ? "min-[930px]:flex-row-reverse" : ""} gap-6 min-[930px]:gap-12 items-start">
              
              <div class="w-full min-[930px]:w-1/2 px-2 min-[930px]:px-4 flex flex-col justify-start items-start">
                <article class="prose prose-sm md:prose-base lg:prose-lg text-gray-700 text-left leading-relaxed break-words">
                  <p class="text-sm md:text-base whitespace-pre-line break-words">${blog.parrafos?.[index]?.parrafo || "Texto no disponible"}</p>
                </article>
              </div>
              
              <div class="relative w-full min-[930px]:w-1/2 h-auto max-w-xl min-[930px]:max-w-none mx-auto overflow-hidden rounded-lg md:rounded-xl shadow-md bg-gray-50">
                <img 
                  src="${
                    imagen.ruta_imagen?.startsWith("http")
                      ? imagen.ruta_imagen
                      : `${getApiUrl}${imagen.ruta_imagen}`
                  }"
                  alt="${imagen.text_alt || "Imagen del blog"}"
                  title="${imagen.text_alt || "Imagen del blog"}"
                  class="w-full h-auto block transition-transform duration-300 hover:scale-105" 
                />
              </div>
              
            </div>
          
            `;
              blogSectionsElement.appendChild(section);
            });
          }

          if (blogVideoSectionElement && blog.video_id) {
            function getYoutubeVideoId(videoValue) {
              if (!videoValue || typeof videoValue !== "string") return "";
              const value = videoValue.trim();
              if (!value) return "";

              const directIdMatch = value.match(/^[a-zA-Z0-9_-]{11}$/);
              if (directIdMatch) return value;

              const urlMatch = value.match(
                /(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/,
              );

              return urlMatch?.[1] || "";
            }

            const validVideoId = getYoutubeVideoId(blog.video_id);

            if (!validVideoId) {
              if (blogVideoContainerElement) {
                blogVideoContainerElement.classList.add("hidden");
              }
            } else {
              if (blogVideoContainerElement) {
                blogVideoContainerElement.classList.remove("hidden");
              }

              blogVideoSectionElement.innerHTML = `
            <section class="rounded-lg md:rounded-xl shadow-md py-4 md:py-4 px-4 md:px-20 bg-gray-50">
                <h1 class="text-lg md:text-xl lg:text-2xl text-sky-400 font-bold mb-4 md:mb-6 text-center md:text-left break-words">${blog.video_titulo}</h1>
                <div class="relative w-full h-48 md:h-64 lg:h-[30rem] rounded-lg overflow-hidden">
                    <iframe
                        width="100%"
                        height="100%"
                        src="https://www.youtube.com/embed/${validVideoId}"
                        title="YouTube video player"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        referrerpolicy="strict-origin-when-cross-origin"
                        allowfullscreen
                        class="rounded-lg w-full h-full"
                    ></iframe>
                </div>
            </section>
          `;
            }
          } else if (blogVideoContainerElement) {
            blogVideoContainerElement.classList.add("hidden");
          }

          clearTimeout(safetyTimeout);
          removeLoaderSafe();
        } catch (error) {

          console.error("=========== ERROR BLOG ===========");
          console.error(error);
          console.error(error?.stack);
          console.error("==================================");

          const blogHeader = document.getElementById("blog-header");
          if (blogHeader) {
            blogHeader.style.display = "none";
          }

          const blogContent = document.getElementById("blog-content");
           if (blogContent) {
            blogContent.classList.add("mt-24", "md:mt-32", "min-h-[50vh]", "flex", "flex-col", "items-center", "justify-center");
            
            blogContent.innerHTML = `
            <div class="text-center p-8 md:py-10">
              <h2 class="text-3xl font-bold text-red-600 mb-4">Error al cargar el blog</h2>
              <p class="text-gray-600 mb-8 text-lg max-w-2xl mx-auto">No se pudo cargar el contenido del blog o el enlace es incorrecto. Por favor, verifica la URL e intenta nuevamente.</p>
              <button onclick="window.location.reload()" class="bg-blue-500 text-white px-8 py-3 rounded-lg hover:bg-blue-600 font-bold shadow-lg transition-transform hover:scale-105">
                Reintentar
              </button>
            </div>
          `;
          }

          clearTimeout(safetyTimeout);
          removeLoaderSafe();
        }
      });

      window.addEventListener("load", () => {
        setTimeout(() => {
          const loader = document.getElementById("page-loader");
          if (loader) loader.remove();
        }, 500);
      });
      window.addEventListener("error", (event) => {
        if (event.error?.message?.includes("classList")) removeLoaderSafe();
      });
    </script>
  </main></Layout
>
