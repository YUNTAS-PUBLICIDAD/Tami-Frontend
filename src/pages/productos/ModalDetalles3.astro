---
import { config } from "config";

interface ModalProps {
  seccion?: string;
  link?: string;
}

const numeroWhatsApp = "51978883199";
const DEFAULT_IMAGE = "/images/popup/default.webp";
const { link = "", seccion = "" } = Astro.props as ModalProps;
---

<div
  id="modal-detalles-3"
  class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center px-4 hidden"
>
  <div
    class="relative flex flex-col sm:flex-row w-[92%] max-w-md sm:max-w-4xl h-[650px] sm:h-auto max-h-[90vh] sm:max-h-none rounded-2xl overflow-hidden shadow-2xl animate-slideIn"
  >
    <button
      id="close-modal-detalles-3"
      class="absolute top-4 right-4 bg-white text-gray-600 hover:text-black w-10 h-10 rounded-full shadow-xl transition hover:scale-110 z-50"
    >
      ✕
    </button>

    <!-- IMAGEN -->
    <div
      id="modal3-image-container"
      class="w-full h-1/2 sm:w-1/2 relative z-20 sm:h-auto sm:min-h-[420px] bg-white overflow-hidden flex items-center justify-center"
    >
      <img
        id="modal3-product-img"
        src={DEFAULT_IMAGE}
        alt="Imagen"
        class="max-h-[85%] max-w-[85%] object-contain transition-all duration-300 ease-in-out"
      />
    </div>

    <!-- FORMULARIO -->
    <div
      id="modal3-form-container"
      class="w-full h-1/2 sm:w-1/2 py-4 px-6 sm:p-12 text-white flex flex-col justify-center sm:justify-center relative z-30 modal3-panel overflow-y-auto sm:overflow-visible"
      data-product-link={link}
      data-seccion={seccion}
      data-whatsapp={numeroWhatsApp}
    >
      <img
        id="modal3-product-img-2"
        src={DEFAULT_IMAGE}
        alt="Imagen de fondo"
        class="absolute inset-0 w-full h-full object-cover z-10 pointer-events-none"
      />

      <h2 id="modal3-title"
        class="relative z-20 text-2xl sm:text-4xl font-bold text-center leading-snug mb-4 hidden sm:block sm:invisible break-words">
      </h2>

      <form id="form-cotizacion-producto-3" class="relative z-20 flex flex-col gap-3" novalidate>
        <p
          data-validation-message
          class="hidden text-base font-bold text-[#FF0000] text-center mb-1 break-words"
        ></p>

        <input
          type="text"
          name="nombre"
          placeholder="Nombre"
          required
          class="input-style"
        />
        <input
          type="email"
          name="correo"
          placeholder="Correo"
          inputmode="email"
          autocomplete="email"
          oninput="this.setCustomValidity(this.validity.typeMismatch ? 'Ingresa un correo valido' : '')"
          required
          class="input-style"
        />
        <input
          type="tel"
          name="telefono"
          placeholder="Telefono"
          inputmode="numeric"
          autocomplete="tel"
          maxlength="9"
          pattern="[0-9]{9}"
          title="Ingresa un telefono de 9 digitos"
          oninput="this.value=this.value.replace(/\D/g,'').slice(0,9)"
          required
          class="input-style"
        />

        <button id="modal3-submit-btn"
          type="submit"
          class="btn-white-pill mt-4 font-bold text-base sm:text-lg self-center w-auto px-8 sm:px-12"
        >
          ¡Solicitar asesoría!
        </button>

        <p class="text-center font-semibold mt-2 hidden sm:block sm:invisible">Asesoría gratuita</p>
      </form>

      <p id="modal3-mensaje" class="relative z-20 text-center mt-4 break-words"></p>
    </div>
  </div>
</div>

<style>
  :global(html),
  :global(body) {
    overflow-x: clip;
  }

  #modal-detalles-3,
  #modal-detalles-3 > div {
    overflow-x: hidden;
  }

  .modal3-panel {
    background: #2702aa;
  }

  .input-style {
    background: white;
    color: #111;
    padding: 10px 14px;
    font-size: 14px;
    border-radius: 14px;
    border: 2px solid #7aa2ff;
  }

/* 📱 SOLO MÓVIL */
@media (max-width: 640px) {
  .input-style {
    padding: 10px 12px;   /* ↓ menos alto */
    font-size: 14px;      /* ↓ texto un poco más chico */
    border-radius: 12px;  /* opcional */
  }
}


.btn-white-pill {
  /* background: #160063;
  color: white; */
  border-radius: 999px;
  font-weight: bold;
  transition: .3s;
  padding: 0.5rem 1.8rem;
  font-size: 0.9rem;
}

  .btn-white-pill:hover {
    transform: scale(1.05);
  }
</style>

<script>
  import { config } from "config";
  import { origenCliente } from "@data/origenCliente";

  window.__detalleProducto = window.__detalleProducto || null;

  async function actualizarImagenModal3() {
    const container = document.querySelector("#modal3-form-container") as HTMLElement | null;
    const modalImg = document.querySelector("#modal3-product-img") as HTMLImageElement | null;
    const modalImg2 = document.querySelector("#modal3-product-img-2") as HTMLImageElement | null;
    if (!container || !modalImg) return;

    const productLink = container.dataset.productLink || "";
    let imagen = "/images/popup/default.webp";
    let imagenAlt = "Imagen del producto";
    let imagen2 = "/images/popup/default.webp";
    let imagenAlt2 = "Imagen de fondo";
    let modoVisual = "fondo";

    if (!window.__detalleProducto && productLink) {
      try {
        const response = await fetch(
          `${config.apiUrl}/api/v1/productos/link/${productLink}`,
        );
        if (response.ok) {
          const result = await response.json();
          window.__detalleProducto = result.data || result;
        }
      } catch {}
    }

    if (window.__detalleProducto) {
      const producto = window.__detalleProducto;
      const imagenPopup = producto.producto_imagenes?.find(
        (img: any) => img.tipo === "popup",
      );
      const imagenPopup2 = producto.producto_imagenes?.find((img: any) => {
        const tipo = (img?.tipo || "").toLowerCase();
        return tipo === "popup2" || tipo === "popup_2";
      });

      if (imagenPopup?.url_imagen) {
        imagen = `${config.apiUrl}${imagenPopup.url_imagen}`;
        imagenAlt = imagenPopup.texto_alt_SEO || producto.nombre;
      } else if (producto.imagenes?.length > 0) {
        imagen = `${config.apiUrl}${producto.imagenes[0].url_imagen}`;
        imagenAlt = producto.imagenes[0].texto_alt_SEO || producto.nombre;
      }

      if (imagenPopup2?.url_imagen) {
        imagen2 = `${config.apiUrl}${imagenPopup2.url_imagen}`;
        imagenAlt2 = imagenPopup2.texto_alt_SEO || producto.nombre;
      } else {
        imagen2 = imagen;
        imagenAlt2 = imagenAlt;
      }

      // ⭐ CONTROL DESDE CHECKBOX LARAVEL
      if (producto.etiqueta?.popup_estilo === "estilo3") {
        modoVisual = producto.etiqueta.popup3_sin_fondo ? "recorte" : "fondo";
      }

      // Estilos del boton
      const submitBtn3 = document.getElementById("modal3-submit-btn");
      if (submitBtn3) {
        submitBtn3.style.setProperty("background", producto?.etiqueta?.popup_button_color || "", "important");
        submitBtn3.style.setProperty("color", producto?.etiqueta?.popup_text_color || "");
        submitBtn3.textContent = producto?.etiqueta?.popup_button_text?.trim() || "¡Solicitar asesoría!";
      }
    }

    const tituloModal3 = document.getElementById("modal3-title");
    if (tituloModal3 && window.__detalleProducto) {
      tituloModal3.textContent = window.__detalleProducto.etiqueta?.titulo_popup_3 || "TU GUÍA DE DECORACIÓN EXCLUSIVA, GRATIS";
    }

    (modalImg as HTMLImageElement).src = imagen;
    (modalImg as HTMLImageElement).alt = imagenAlt;

    if (modalImg2) {
      modalImg2.src = imagen2;
      modalImg2.alt = imagenAlt2;
    }

    modalImg.classList.remove(
      "absolute",
      "inset-0",
      "w-full",
      "h-full",
      "object-cover",
    );
    modalImg.classList.remove("max-h-[85%]", "max-w-[85%]", "object-contain");

    if (modoVisual === "recorte") {
      modalImg.classList.add("max-h-[85%]", "max-w-[85%]", "object-contain");
    } else {
      modalImg.classList.add(
        "absolute",
        "inset-0",
        "w-full",
        "h-full",
        "object-cover",
      );
    }
  }

  /* Cerrar */
  const modal3 = document.getElementById("modal-detalles-3");
  const closeBtn3 = document.getElementById("close-modal-detalles-3");
  if (closeBtn3) closeBtn3.onclick = () => modal3?.classList.add("hidden");

  /* Detectar apertura */
  const observer3 = new MutationObserver(async () => {
    if (!modal3.classList.contains("hidden")) await actualizarImagenModal3();
  });
  observer3.observe(modal3, { attributes: true, attributeFilter: ["class"] });

  /* Envío */
  const form3 = document.getElementById(
    "form-cotizacion-producto-3",
  ) as HTMLFormElement | null;
  const container3 = document.getElementById(
    "modal3-form-container",
  ) as HTMLElement | null;
  const mensaje3 = document.getElementById("modal3-mensaje");

  const normalizeLeadFormValues = (formElement: HTMLFormElement) => {
    const data = new FormData(formElement);
    return {
      nombre: (data.get("nombre")?.toString() || "").trim(),
      telefono: (data.get("telefono")?.toString() || "")
        .replace(/\D/g, "")
        .trim(),
      correo: (data.get("correo")?.toString() || "").trim(),
    };
  };

  const getLeadValidationMessage = ({
    nombre,
    telefono,
    correo,
  }: {
    nombre: string;
    telefono: string;
    correo: string;
  }) => {
    if (!nombre || nombre.length < 3 || nombre.length > 75) {
      return "Ingresa un nombre valido (3 a 75 caracteres)";
    }

    if (!/^\d{9}$/.test(telefono)) {
      return "Ingresa un telefono valido de 9 digitos";
    }

    if (!correo || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo)) {
      return "Ingresa un correo valido";
    }

    return "";
  };

  const setInlineValidationMessage = (
    formElement: HTMLFormElement,
    message: string,
  ) => {
    const messageEl = formElement.querySelector(
      "[data-validation-message]",
    ) as HTMLElement | null;

    if (!messageEl) return;

    if (message) {
      messageEl.textContent = message;
      messageEl.classList.remove("hidden");
      return;
    }

    messageEl.textContent = "";
    messageEl.classList.add("hidden");
  };

  if (form3 && container3) {
    form3
      .querySelectorAll('input[name="nombre"], input[name="telefono"], input[name="correo"]')
      .forEach((input) => {
        input.addEventListener("input", () => setInlineValidationMessage(form3, ""));
      });

    form3.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitBtn = form3.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement | null;
      const originalBtnText = submitBtn ? submitBtn.textContent : "";

      const { nombre, telefono, correo } = normalizeLeadFormValues(form3);
      const validationMessage = getLeadValidationMessage({
        nombre,
        telefono,
        correo,
      });

      if (validationMessage) {
        setInlineValidationMessage(form3, validationMessage);
        return;
      }

      setInlineValidationMessage(form3, "");

      const telefonoConCodigo = `+51${telefono}`;
      const productLink = container3.dataset.productLink;

      // 1. Estado de carga
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Solicitando...";
      }

      // 2. Cerrar modal rápidamente
      if (modal3) modal3.classList.add("hidden");

      // 3. Notificar al usuario
      window.dispatchEvent(
        new CustomEvent("show-toast", {
          detail: {
            message: "¡Información enviada! Gracias por tu interés.",
            type: "success",
          },
        }),
      );

      // 4. Enviar en segundo plano
      try {
        // crear cliente
        const formData = new FormData();
        formData.append("name", nombre);
        formData.append("email", correo);
        formData.append("celular", telefonoConCodigo);
        formData.append("source_id", origenCliente.PRODUCTO_DETALLE);
        formData.append("producto_id", window.__detalleProducto?.id || "");

        const response = await fetch(`${config.apiUrl}${config.endpoints.clientes.create}`, {
          method: "POST",
          body: formData,
        }).catch(() => {});

        if (response && response.ok) {
          const p1 = fetch(`${config.apiUrl}${config.endpoints.whatsapp.info}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              link: productLink,
              phone: telefonoConCodigo,
              email: correo ?? null,
            }),
          }).catch(() => {});

          const p2 = fetch(
            `${config.apiUrl}${config.endpoints.email.sendEmailByProductLink}`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                name: nombre,
                celular: telefonoConCodigo,
                email: correo,
                link: productLink,
              }),
            },
          ).catch(() => {});

          await Promise.all([p1, p2]);
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
        }
        form3.reset();
      }
    });
  }
</script>
