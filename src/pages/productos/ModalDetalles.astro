---
interface ModalProps {
  seccion?: string;
  link?: string;
}

import { DEFAULT_IMAGE } from "../../constants";

const numeroWhatsApp = "51978883199";

const { link = "" } = Astro.props as ModalProps;
---

<!-- Modal -->
<div
  id="modal-cotizacion-producto"
  class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center px-4 hidden"
>
  <div
    class="relative flex flex-col sm:flex-row w-[85%] max-w-md sm:max-w-4xl h-[560px] sm:h-auto max-h-[90vh] sm:max-h-none rounded-2xl overflow-hidden shadow-2xl animate-slideIn"
  >
    <button
      id="close-modal-cotizacion"
      aria-label="Cerrar modal"
      class="absolute top-3 right-3 sm:top-4 sm:right-4 bg-white text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-full w-10 h-10 sm:w-11 sm:h-11 flex items-center justify-center shadow-xl transition-all duration-300 hover:scale-110 cursor-pointer z-[60]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2.5"
        stroke="currentColor"
        class="w-6 h-6 sm:w-6 sm:h-6"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <div id="background-modal" class="absolute inset-0 z-20"></div>

    <!-- Contenedor de imagen - Modificado para centrar y ajustar correctamente -->

    <div class="w-full sm:w-1/2 h-1/2 sm:h-auto relative z-20 bg-[#0c1142]">
      <!-- Wrapper anti-corte -->
      <div class="h-full flex items-center justify-center p-6">
        <img
          id="modal-product-img"
          src={DEFAULT_IMAGE}
          alt="Imagen del producto"
          class="w-full h-full object-contain"
        />
      </div>
    </div>

    <!-- Formulario dinámico -->
    <div
      id="modal-form-container"
      class="w-full h-1/2 sm:w-1/2 py-4 px-6 sm:p-12 text-white flex flex-col justify-center sm:justify-center relative z-30 overflow-y-auto sm:overflow-visible"
      data-product-link={link}
      data-seccion={Astro.props.seccion}
      data-whatsapp={numeroWhatsApp}
    >
      <img
        id="modal-product-img-2"
        src={DEFAULT_IMAGE}
        alt="Imagen del fondo del formulario"
        class="absolute inset-0 w-full h-full object-cover z-10 pointer-events-none"
      />
      <div
        class="relative z-20 p-8 sm:py-10 sm:mx-8 min-h-[480px] flex flex-col justify-center"
      >
        <!-- TÍTULO DINÁMICO (ESTILO 1) -->
        <h2
          id="modal-title"
          class="mx-auto max-w-[320px] text-xl sm:text-3xl font-light text-center leading-[1.25] sm:leading-[1.2] mb-6 hidden sm:block sm:invisible break-words"
        >
          Descubre tu guia exclusiva de decoracion TOTALMENTE<br />
          <span class="font-extrabold">GRATIS</span>
        </h2>

        <form id="form-cotizacion-producto" class="relative z-20 flex flex-col gap-3" novalidate>
          <p
            data-validation-message
            class="hidden text-base font-bold text-[#FF0000] text-center mb-1 break-words"
          ></p>

          <div class="relative mb-1">
            <div class="absolute left-3 top-1/2 -translate-y-1/2 text-[#1B7C72] scale-75 sm:scale-100">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </div>
            <input
              type="text"
              name="nombre"
              class="w-full h-[28px] sm:h-auto p-0 sm:p-2.5 pl-10 rounded-full bg-white text-black border-2 input-style text-[10px] sm:text-sm"
              placeholder="Tu nombre"
              required
            />
          </div>

          <div class="relative mb-1">
            <div class="absolute left-3 top-1/2 -translate-y-1/2 text-[#1B7C72] scale-75 sm:scale-100">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            </div>
            <input
              type="email"
              name="correo"
              class="w-full h-[28px] sm:h-auto p-0 sm:p-2.5 pl-10 rounded-full bg-white text-black border-2 input-style text-[10px] sm:text-sm"
              placeholder="Tu correo"
              inputmode="email"
              autocomplete="email"
              oninput="this.setCustomValidity(this.validity.typeMismatch ? 'Ingresa un correo valido' : '')"
              required
            />
          </div>

          <div class="relative mb-1">
            <div class="absolute left-3 top-1/2 -translate-y-1/2 text-[#1B7C72] scale-75 sm:scale-100">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.148-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.628 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"></path></svg>
            </div>
            <input
              type="tel"
              name="telefono"
              class="w-full h-[28px] sm:h-auto p-0 sm:p-2.5 pl-10 rounded-full bg-white text-black border-2 mb-1 input-style text-[10px] sm:text-sm"
              placeholder="Tu WhatsApp"
              inputmode="numeric"
              autocomplete="tel"
              maxlength="9"
              pattern="[0-9]{9}"
              title="Ingresa un telefono de 9 digitos"
              oninput="this.value=this.value.replace(/\\D/g,'').slice(0,9)"
              required
            />
          </div>

          <button
            id="modal-submit-btn"
            type="submit"
            class="mt-3 py-1.5 rounded-lg text-white font-bold transition-all duration-300 shadow-lg text-sm"
          >
            buttonText
          </button>
          <p
            id="modal-negocios-text"
            class="text-center mt-3 text-base sm:text-lg text-white font-bold tracking-wide hidden sm:block sm:invisible"
          >
            Asesoría gratuita
          </p>
        </form>
        <p id="modal-cotizacion-mensaje" class="text-center mt-4 break-words"></p>
      </div>
    </div>
  </div>
</div>

<script>
  import { config } from "config";
  import { origenCliente } from "@data/origenCliente";
  import { getPublicPopupSettings } from "../../lib/api/popupSettings";
  import { DEFAULT_IMAGE } from "../../constants";

  declare global {
    interface Window {
      __detalleProductoSeccion?: string;
      __detalleProducto?: any;
    }
  }

  // --- CONFIGURACIÓN POR SECCIÓN ---
  const secciones = {
    NEGOCIOS: {
      gradient: "custom-gradient-negocio",
      title: "Descubre tu guía exclusiva de negocio TOTALMENTE GRATIS",
      btn: "btn-gradient-negocio-fix border border-white cursor-pointer", // Cambiado aquí
      buttonText: "¡COTIZA AHORA!",
    },
    MAQUINARIA: {
      gradient: "custom-gradient-maquinaria",
      title: "Descubre tu guía exclusiva de maquinaria TOTALMENTE GRATIS",
      btn: "btn-gradient-negocio-fix border border-white cursor-pointer",
      buttonText: "¡COTIZA AHORA!",
    },
    DECORACIÓN: {
      gradient: "custom-gradient-decoracion",
      title: "Descubre tu guía exclusiva de decoración TOTALMENTE GRATIS",
      btn: "btn-gradient-negocio-fix border border-white cursor-pointer",
      buttonText: "¡COTIZA AHORA!",
    },
  };

  // Imagen por defecto (solo fallback)


  const container = document.getElementById("modal-form-container");
  const numeroWhatsApp = container?.dataset.whatsapp ?? "51978883199";

  let sectionConfig = secciones.NEGOCIOS;

  function enforcePhoneOnlyNineDigits(input: HTMLInputElement) {
    const sanitizeValue = () => {
      input.value = input.value.replace(/\D/g, "").slice(0, 9);
    };

    input.setAttribute("inputmode", "numeric");
    input.setAttribute("maxlength", "9");
    input.setAttribute("pattern", "[0-9]{9}");
    input.setAttribute("title", "Ingresa un telefono de 9 digitos");

    input.addEventListener("keydown", (e) => {
      const allowedKeys = [
        "Backspace",
        "Delete",
        "ArrowLeft",
        "ArrowRight",
        "Tab",
        "Home",
        "End",
      ];

      if (allowedKeys.includes(e.key) || e.ctrlKey || e.metaKey) return;
      if (!/^\d$/.test(e.key)) {
        e.preventDefault();
      }
    });

    input.addEventListener("input", sanitizeValue);
    input.addEventListener("paste", (e) => {
      e.preventDefault();
      const pasted = e.clipboardData?.getData("text") || "";
      input.value = pasted.replace(/\D/g, "").slice(0, 9);
      input.dispatchEvent(new Event("input", { bubbles: true }));
    });

    sanitizeValue();
  }

  document
    .querySelectorAll('input[name="telefono"]')
    .forEach((element) => enforcePhoneOnlyNineDigits(element as HTMLInputElement));

  // --- LÓGICA DE MOSTRAR / CERRAR ---
  const MODAL_STORAGE_KEY = "asesoriaModalLastClosedDetalle";
  const MODAL_COOLDOWN_MS = 3 * 60 * 1000; // 3 minutos
  let modalTimeout: ReturnType<typeof setTimeout> | null = null;
  let countdownInterval: ReturnType<typeof setInterval> | null = null;
  let modalMostrado = false;

  async function obtenerProductoActual() {
    const container = document.getElementById("modal-form-container");
    const productLink = container?.dataset.productLink;

    if (!productLink) return null;

    if (window.__detalleProducto) return window.__detalleProducto;

    try {
      const response = await fetch(
        `${config.apiUrl}/api/v1/productos/link/${productLink}`,
      );
      if (response.ok) {
        const result = await response.json();
        window.__detalleProducto = result.data || result;
        return window.__detalleProducto;
      }
    } catch (e) {}

    return null;
  }

  function cerrarTodosLosModales() {
    document
      .getElementById("modal-cotizacion-producto")
      ?.classList.add("hidden");
    document.getElementById("modal-detalles-2")?.classList.add("hidden");
    document.getElementById("modal-detalles-3")?.classList.add("hidden");
  }

  function obtenerTituloPopup(producto: any) {
    const etiqueta = producto?.etiqueta;
    if (!etiqueta) return sectionConfig.title;

    switch (etiqueta.popup_estilo) {
      case "estilo1":
        return etiqueta.titulo_popup_1 || sectionConfig.title;
      case "estilo2":
        return etiqueta.titulo_popup_2 || sectionConfig.title;
      case "estilo3":
        return etiqueta.titulo_popup_3 || sectionConfig.title;
      default:
        return sectionConfig.title;
    }
  }

  async function showCotizacionModal() {
    if (modalTimeout) {
      clearTimeout(modalTimeout);
      modalTimeout = null;
    }
    if (countdownInterval) {
      clearInterval(countdownInterval);
      countdownInterval = null;
    }

    const producto = await obtenerProductoActual();
    console.log("PRODUCTO COMPLETO:", producto);
    console.log("ETIQUETA COMPLETA:", producto?.etiqueta);
    console.log("TITULO 1:", producto?.etiqueta?.titulo_popup_1);
    console.log("TITULO 2:", producto?.etiqueta?.titulo_popup_2);
    console.log("TITULO 3:", producto?.etiqueta?.titulo_popup_3);
    await actualizarImagenDesdeLink();
    console.log("🧾 Titulos popup:", producto?.etiqueta);

    cerrarTodosLosModales();

    const popupEstilo = producto?.etiqueta?.popup_estilo || "estilo1";
    const titleEl = document.getElementById("modal-title");
    if (titleEl) {
      const tituloFinal = obtenerTituloPopup(producto);
      titleEl.innerHTML = tituloFinal.replace(
        "GRATIS",
        "<span class='font-extrabold'>GRATIS</span>",
      );
    }

    if (popupEstilo === "estilo2") {
      document.getElementById("modal-detalles-2")?.classList.remove("hidden");
      modalMostrado = true;
      return;
    }

    if (popupEstilo === "estilo3") {
      document.getElementById("modal-detalles-3")?.classList.remove("hidden");
      modalMostrado = true;
      return;
    }

    // ---- ESTILO 1 (TU MODAL ACTUAL) ----
    aplicarConfig();

    const modal = document.getElementById("modal-cotizacion-producto");
    const mensaje = document.getElementById("modal-cotizacion-mensaje");

    if (modal && mensaje) {
      modal.classList.remove("hidden");
      mensaje.textContent = "";
      modalMostrado = true;
    }

    // Estilos del boton
    document
      .getElementById("modal-submit-btn")
      ?.style.setProperty(
        "background",
        producto?.etiqueta?.popup_button_color,
        "important",
      );
    document
      .getElementById("modal-submit-btn")
      ?.style.setProperty("color", producto?.etiqueta?.popup_text_color);

    const popupButtonText = producto?.etiqueta?.popup_button_text?.trim();
    const submitBtn = document.getElementById("modal-submit-btn");
    if (submitBtn) {
      submitBtn.textContent =
        popupButtonText || sectionConfig.buttonText || "¡COTIZA AHORA!";
    }
  }

  // Imagen por defecto (industrial/fábrica)


  async function actualizarImagenDesdeLink() {
    const container = document.getElementById("modal-form-container");
    const modalImg = document.getElementById(
      "modal-product-img",
    ) as HTMLImageElement | null;
    const modalImg2 = document.getElementById(
      "modal-product-img-2",
    ) as HTMLImageElement | null;

    if (!container || (!modalImg && !modalImg2)) return;

    const productLink = container.dataset.productLink || "";
    let imagen = DEFAULT_IMAGE;
    let imagenAlt = "Imagen del producto";
    let imagen2 = DEFAULT_IMAGE;
    let imagenAlt2 = "Imagen de fondo del formulario";

    // Cargar producto desde API si no está en caché
    if (!window.__detalleProducto && productLink) {
      try {
        const response = await fetch(
          `${config.apiUrl}/api/v1/productos/link/${productLink}`,
        );
        if (response.ok) {
          const result = await response.json();
          window.__detalleProducto = result.data || result;
        }
      } catch (error) {}
    }

    if (window.__detalleProducto) {
      const producto = window.__detalleProducto;
      // Detección más inclusiva (celulares y tablets)
      const isMobileDevice = window.innerWidth < 1024 || window.matchMedia("(max-width: 1023px)").matches;

      // Buscar tipos de imágenes en la colección completa
      const allImages = producto.producto_imagenes || producto.imagenes || [];
      const imgPopup = allImages.find((img: any) => img.tipo === "popup");
      const imgPopup2 = allImages.find((img: any) => img.tipo === "popup2" || img.tipo === "popup_2");
      const imgMobile = allImages.find((img: any) => img.tipo === "popup_mobile");
      const imgMobile2 = allImages.find((img: any) => img.tipo === "popup_mobile2");

      // Imagen de respaldo profesional para productos
      const FALLBACK = "/images/hero/impulso-negocios-tecnologia.webp";

      if (isMobileDevice) {
        // MODO MÓVIL: Prioridad absoluta a imágenes móviles o fallback
        if (imgMobile?.url_imagen) {
          imagen = `${config.apiUrl}${imgMobile.url_imagen}`;
          imagenAlt = imgMobile.texto_alt_SEO || producto.nombre;
        } else {
          imagen = FALLBACK;
          imagenAlt = "Diseño industrial Tami";
        }

        if (imgMobile2?.url_imagen) {
          imagen2 = `${config.apiUrl}${imgMobile2.url_imagen}`;
          imagenAlt2 = imgMobile2.texto_alt_SEO || producto.nombre;
        } else {
          imagen2 = FALLBACK;
          imagenAlt2 = "Diseño industrial Tami";
        }
      } else {
        // MODO ESCRITORIO
        if (imgPopup?.url_imagen) {
          imagen = `${config.apiUrl}${imgPopup.url_imagen}`;
          imagenAlt = imgPopup.texto_alt_SEO || producto.nombre;
        } else if (producto.imagenes?.length > 0) {
          imagen = `${config.apiUrl}${producto.imagenes[0].url_imagen}`;
          imagenAlt = producto.imagenes[0].texto_alt_SEO || producto.nombre;
        }

        if (imgPopup2?.url_imagen) {
          imagen2 = `${config.apiUrl}${imgPopup2.url_imagen}`;
          imagenAlt2 = imgPopup2.texto_alt_SEO || producto.nombre;
        } else {
          imagen2 = imagen;
          imagenAlt2 = imagenAlt;
        }
      }
    }

    if (modalImg) {
      modalImg.src = imagen;
      modalImg.alt = imagenAlt;
      modalImg.onerror = () => { modalImg.src = DEFAULT_IMAGE; };
    }

    if (modalImg2) {
      modalImg2.src = imagen2;
      modalImg2.alt = imagenAlt2;
      modalImg2.onerror = () => { modalImg2.src = DEFAULT_IMAGE; };
    }
  }

  function puedeMostrarModal() {
    const lastClosed = parseInt(
      localStorage.getItem(MODAL_STORAGE_KEY) || "0",
      10,
    );
    return Date.now() - lastClosed >= MODAL_COOLDOWN_MS;
  }

  let currentCallId = 0;

  async function programarPopupAutomatico() {
    const myId = ++currentCallId;

    if (modalTimeout) {
      clearTimeout(modalTimeout);
      modalTimeout = null;
    }
    if (countdownInterval) {
      clearInterval(countdownInterval);
      countdownInterval = null;
    }

    if (!puedeMostrarModal() || modalMostrado) return;

    try {
      let settings = await getPublicPopupSettings();

      // IF a new call started while we were waiting, ABORT this one
      if (myId !== currentCallId) return;

      // Re-verify after await
      if (modalMostrado || !puedeMostrarModal()) return;

      // Override with localStorage if exists (matching ScrollModal.tsx behavior)
      if (typeof window !== "undefined") {
        const savedProductDelay = localStorage.getItem("popupProductDelay");
        if (savedProductDelay) {
          settings = {
            ...settings,
            product_popup_delay_minutes: parseInt(savedProductDelay),
          };
        }
      }

      const delayMinutes = settings.product_popup_delay_minutes ?? 1;
      const delayMs = delayMinutes * 60 * 1000;

      // Final double check before setting timers
      if (modalTimeout) clearTimeout(modalTimeout);
      if (countdownInterval) clearInterval(countdownInterval);

      let remainingMs = delayMs;
      countdownInterval = setInterval(() => {
        remainingMs -= 1000;
        if (remainingMs <= 0) {
          if (countdownInterval) {
            clearInterval(countdownInterval);
            countdownInterval = null;
          }
          return;
        }
        // const minutes = Math.floor(remainingMs / 60000);
        // const seconds = Math.floor((remainingMs % 60000) / 1000);
      }, 1000);

      modalTimeout = setTimeout(async () => {
        if (myId !== currentCallId) return;
        if (modalMostrado || !puedeMostrarModal()) return;
        await showCotizacionModal();
      }, delayMs);
    } catch (e) {
      console.error("Error programando popup:", e);
    }
  }

  const closeBtn = document.getElementById("close-modal-cotizacion");
  if (closeBtn) {
    closeBtn.onclick = () => {
      const modal = document.getElementById("modal-cotizacion-producto");
      if (modal) modal.classList.add("hidden");
      if (modalTimeout) {
        clearTimeout(modalTimeout);
        modalTimeout = null;
      }
      if (countdownInterval) {
        clearInterval(countdownInterval);
        countdownInterval = null;
      }
      localStorage.setItem(MODAL_STORAGE_KEY, Date.now().toString());
    };
  }

  // --- FORMULARIO ---
  const form = document.getElementById(
    "form-cotizacion-producto",
  ) as HTMLFormElement | null;

  const normalizeLeadFormValues = (formElement: HTMLFormElement) => {
    const data = new FormData(formElement);
    return {
      nombre: (data.get("nombre")?.toString() || "").trim(),
      telefono: (data.get("telefono")?.toString() || "")
        .replace(/\D/g, "")
        .trim(),
      correo: (data.get("correo")?.toString() || "").trim(),
    };
  };

  const getLeadValidationMessage = ({
    nombre,
    telefono,
    correo,
  }: {
    nombre: string;
    telefono: string;
    correo: string;
  }) => {
    if (!nombre || nombre.length < 3 || nombre.length > 75) {
      return "Ingresa un nombre valido (3 a 75 caracteres)";
    }

    if (!/^\d{9}$/.test(telefono)) {
      return "Ingresa un telefono valido de 9 digitos";
    }

    if (!correo || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo)) {
      return "Ingresa un correo valido";
    }

    return "";
  };

  const setInlineValidationMessage = (
    formElement: HTMLFormElement,
    message: string,
  ) => {
    const messageEl = formElement.querySelector(
      "[data-validation-message]",
    ) as HTMLElement | null;

    if (!messageEl) return;

    if (message) {
      messageEl.textContent = message;
      messageEl.classList.remove("hidden");
      return;
    }

    messageEl.textContent = "";
    messageEl.classList.add("hidden");
  };

  if (form) {
    form
      .querySelectorAll('input[name="nombre"], input[name="telefono"], input[name="correo"]')
      .forEach((input) => {
        input.addEventListener("input", () => setInlineValidationMessage(form, ""));
      });

    form.onsubmit = async (e) => {
      e.preventDefault();

      const submitBtn = document.getElementById(
        "modal-submit-btn",
      ) as HTMLButtonElement | null;
      const originalBtnText = submitBtn ? submitBtn.textContent : "";

      const { nombre, telefono, correo } = normalizeLeadFormValues(form);
      const validationMessage = getLeadValidationMessage({
        nombre,
        telefono,
        correo,
      });

      if (validationMessage) {
        setInlineValidationMessage(form, validationMessage);
        return;
      }

      setInlineValidationMessage(form, "");

      const telefonoConCodigo = `+51${telefono}`;
      const container = document.getElementById("modal-form-container");
      const productLink = container?.dataset.productLink;

      // 1. Estado de carga inmediato
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Cotizando...";
      }

      // 2. Cerrar modal rápidamente
      const modal = document.getElementById("modal-cotizacion-producto");
      if (modal) modal.classList.add("hidden");

      // 3. Notificar al usuario inmediatamente
      window.dispatchEvent(
        new CustomEvent("show-toast", {
          detail: {
            message: "¡Información enviada! En breve te contactaremos.",
            type: "success",
          },
        }),
      );

      // 4. Enviar datos en segundo plano
      try {
        // crear cliente
        const formData = new FormData();
        formData.append("name", nombre);
        formData.append("email", correo);
        formData.append("celular", telefonoConCodigo);
        formData.append("source_id", origenCliente.PRODUCTO_DETALLE);
        formData.append("producto_id", window.__detalleProducto?.id || "");

        const response = await fetch(
          `${config.apiUrl}${config.endpoints.clientes.create}`,
          {
            method: "POST",
            body: formData,
          },
        ).catch(() => {});

        if (response && response.ok) {
          // WhatsApp
          const p1 = fetch(
            `${config.apiUrl}${config.endpoints.whatsapp.info}`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                link: productLink,
                phone: telefonoConCodigo,
                email: correo ?? null,
              }),
            },
          ).catch((err) => console.error("Error WhatsApp background:", err));

          // Email
          const p2 = fetch(
            `${config.apiUrl}${config.endpoints.email.sendEmailByProductLink}`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                name: nombre,
                phone: telefonoConCodigo,
                celular: telefonoConCodigo,
                telefono: telefonoConCodigo,
                email: correo,
                link: productLink || window.location.href,
              }),
            },
          ).catch((err) => console.error("Error Email background:", err));

          // Esperar un poco antes de resetear por si el usuario vuelve a abrir el modal
          await Promise.all([p1, p2]);
        }
      } catch (error) {
        console.error("Error en el envío:", error);
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
        }
        form.reset();
        localStorage.setItem(MODAL_STORAGE_KEY, Date.now().toString());
      }
    };
  }

  // ====== CONECTAR OTROS MODALES AL MISMO ENVÍO ======
  const extraForms = document.querySelectorAll<HTMLFormElement>(
    ".form-cotizacion-producto",
  );

  extraForms.forEach((formExtra) => {
    if (formExtra.id === "form-cotizacion-producto") return; // evitar duplicar el principal

    formExtra.addEventListener("submit", async (e) => {
      e.preventDefault();

      const container = formExtra.closest<HTMLElement>("[data-product-link]");
      const mensajeEl = container?.querySelector(".modal-cotizacion-mensaje");

      const data = new FormData(formExtra);
      const nombre = data.get("nombre");
      const telefono = "+51 " + data.get("telefono");
      const correo = data.get("correo");
      const productLink = container?.dataset.productLink;

      // === WHATSAPP (MISMA LÓGICA QUE YA USAS) ===
      try {
        await fetch(`${config.apiUrl}${config.endpoints.whatsapp.info}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            link: productLink,
            phone: telefono,
            email: correo ?? null,
          }),
        });

        if (mensajeEl) mensajeEl.textContent = "WhatsApp enviado ✅";
      } catch (error) {
        if (mensajeEl) mensajeEl.textContent = "WhatsApp falló ❌";
      }

      // === EMAIL ===
      try {
        const response = await fetch(
          `${config.apiUrl}${config.endpoints.email.sendEmailByProductLink}`,
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              name: nombre,
              phone: telefono,
              celular: telefono,
              telefono: telefono,
              email: correo,
              link: productLink || window.location.href,
            }),
          },
        );

        if (response.ok) {
          if (mensajeEl)
            mensajeEl.textContent += mensajeEl.textContent
              ? " | Correo enviado ✅"
              : "Correo enviado ✅";
        } else {
          if (mensajeEl)
            mensajeEl.textContent += mensajeEl.textContent
              ? " | Correo falló ❌"
              : "Correo falló ❌";
        }
      } catch {
        if (mensajeEl)
          mensajeEl.textContent += mensajeEl.textContent
            ? " | Correo falló ❌"
            : "Correo falló ❌";
      }

      formExtra.reset();
    });
  });

  function aplicarConfig() {
    const backgroundModal = document.getElementById("background-modal");
    const formContainer = document.getElementById("modal-form-container");
    const title = document.getElementById("modal-title");
    const btn = document.getElementById("modal-submit-btn");

    // GRADIENTE DE FONDO
    if (backgroundModal) {
      // Limpiar gradientes anteriores antes de agregar el nuevo
      backgroundModal.classList.remove(
        "custom-gradient-negocio",
        "custom-gradient-maquinaria",
        "custom-gradient-decoracion",
      );
      backgroundModal.classList.add(sectionConfig.gradient);
    }

    /* negociosText movido a invisible/hidden vía CSS en el HTML */

    if (btn) {
      // Resetear clases de botón completamente para evitar conflictos de Tailwind
      btn.className =
        "mt-4 py-2 rounded-lg text-white transition-all duration-300 shadow-lg font-bold";

      // Aplicar las clases específicas de la sección
      const extraClasses = sectionConfig.btn.split(" ");
      btn.classList.add(...extraClasses);

      // Aplicar texto
      btn.textContent = sectionConfig.buttonText || "¡COTIZA AHORA!";
    }
  }

  // Configurar botones de cotización
  function configurarBotonesCotizacion() {
    const botones = document.querySelectorAll('[id^="btnQuotation"]');
    botones.forEach((boton) => {
      boton.addEventListener("click", async () => {
        await showCotizacionModal();
      });
    });
  }

  // Mostrar modal por evento o scroll
  window.addEventListener("open-scroll-modal", async () => {
    await showCotizacionModal();
  });

  // Actualizar sección dinámicamente
  function updateSectionFromDataset() {
    const container = document.getElementById("modal-form-container");
    if (!container) return;

    const rawSection = container.dataset.seccion || "NEGOCIOS";
    const normalized = rawSection
      .normalize?.("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toUpperCase();
    const keyMap = {
      NEGOCIOS: "NEGOCIOS",
      MAQUINARIA: "MAQUINARIA",
      DECORACION: "DECORACIÓN",
    } as const;

    const productoSeccion = (keyMap[normalized as keyof typeof keyMap] ||
      "NEGOCIOS") as keyof typeof secciones;
    sectionConfig = secciones[productoSeccion] || secciones.NEGOCIOS;

    aplicarConfig();
  }

  // Observer para detectar cambios en data-seccion y data-product-link
  if (container) {
    const observer = new MutationObserver((mutations) => {
      mutations.forEach(async (mutation) => {
        if (mutation.attributeName === "data-seccion") {
          updateSectionFromDataset();
        }
        if (mutation.attributeName === "data-product-link") {
          await actualizarImagenDesdeLink();
          programarPopupAutomatico();
        }
      });
    });

    observer.observe(container, {
      attributes: true,
      attributeFilter: ["data-seccion", "data-product-link"],
    });
  }

  // Inicializar
  document.addEventListener("DOMContentLoaded", async function () {
    localStorage.removeItem("asesoriaModalLastClosedDetalle");

    updateSectionFromDataset();
    await actualizarImagenDesdeLink();
    configurarBotonesCotizacion();
    programarPopupAutomatico();
  });
</script>

