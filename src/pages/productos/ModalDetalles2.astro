---
import { config } from "config";

interface ModalProps {
  seccion?: string;
  link?: string;
}

const numeroWhatsApp = "51978883199";
const DEFAULT_IMAGE = "/images/popup/default.webp";
const { link = "", seccion = "" } = Astro.props as ModalProps;
---

<div
  id="modal-detalles-2"
  class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center px-4 hidden"
>
  <div
    class="relative flex flex-col sm:flex-row w-[92%] max-w-md sm:max-w-4xl h-[650px] sm:h-auto max-h-[90vh] sm:max-h-none rounded-2xl overflow-hidden shadow-2xl animate-slideIn"
  >
    <button
      id="close-modal-detalles-2"
      class="absolute top-4 right-4 bg-white text-gray-600 hover:text-black w-10 h-10 rounded-full shadow-xl transition hover:scale-110 z-50"
    >
      ✕
    </button>

    <!-- IMAGEN -->
    <div
      class="w-full h-1/2 sm:w-1/2 relative z-20 sm:h-auto sm:min-h-[420px]"
    >
      <img
        id="modal2-product-img"
        src={DEFAULT_IMAGE}
        alt="Imagen"
        class="absolute inset-0 w-full h-full object-cover"
      />
    </div>

    <!-- FORM -->
    <div id="modal2-form-container"
      class="w-full h-1/2 sm:w-1/2 py-4 px-6 sm:p-12 text-white flex flex-col justify-center sm:justify-center relative z-30 modal-blue-panel overflow-y-auto sm:overflow-visible"
      data-product-link={link}
      data-seccion={seccion}
      data-whatsapp={numeroWhatsApp}
    >
      <img
        id="modal2-product-img-2"
        src={DEFAULT_IMAGE}
        alt="Imagen de fondo"
        class="absolute inset-0 w-full h-full object-cover z-10 pointer-events-none"
      />

      <!-- TÍTULO DINÁMICO -->
      <h2 id="modal2-title" class="relative z-20 text-3xl sm:text-4xl font-light text-center leading-snug mb-4 hidden sm:block sm:invisible break-words">
        Tu guía de decoración exclusiva,<br>
        <span class="font-extrabold">Gratis</span>
      </h2>

      <form id="form-cotizacion-producto-2" class="relative z-20 flex flex-col gap-3" novalidate>
        <p
          data-validation-message
          class="hidden text-base font-bold text-[#FF0000] text-center mb-1 break-words"
        ></p>

        <div class="relative mb-1">
          <div class="absolute left-3 top-1/2 -translate-y-1/2 text-[#1B7C72]">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
          <input
            type="text"
            name="nombre"
            placeholder="Tu nombre"
            required
            class="input-style w-full pl-10"
          />
        </div>

        <div class="relative mb-1">
          <div class="absolute left-3 top-1/2 -translate-y-1/2 text-[#1B7C72]">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          </div>
          <input
            type="email"
            name="correo"
            placeholder="Tu correo"
            inputmode="email"
            autocomplete="email"
            oninput="this.setCustomValidity(this.validity.typeMismatch ? 'Ingresa un correo valido' : '')"
            required
            class="input-style w-full pl-10"
          />
        </div>

        <div class="relative mb-1">
          <div class="absolute left-3 top-1/2 -translate-y-1/2 text-[#1B7C72]">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.148-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.628 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"></path></svg>
          </div>
          <input
            type="tel"
            name="telefono"
            placeholder="Tu WhatsApp"
            inputmode="numeric"
            autocomplete="tel"
            maxlength="9"
            pattern="[0-9]{9}"
            title="Ingresa un telefono de 9 digitos"
            oninput="this.value=this.value.replace(/\\D/g,'').slice(0,9)"
            required
            class="input-style w-full pl-10"
          />
        </div>

        <button id="modal2-submit-btn"
          type="submit"
          class="btn-white-pill mt-4 font-bold text-lg sm:text-3xl self-center w-auto px-10 sm:px-14"
        >
          ¡Cotiza ahora!
        </button>
      </form>

      <p id="modal2-cotizacion-mensaje" class="relative z-20 text-center mt-4 break-words"></p>
    </div>
  </div>
</div>

<style>
  :global(html),
  :global(body) {
    overflow-x: clip;
  }

  #modal-detalles-2,
  #modal-detalles-2 > div {
    overflow-x: hidden;
  }

  .modal-blue-panel {
    background: linear-gradient(180deg, #002ade 0%, #003a9f 40%, #004c5d 100%);
  }

.input-style {
  background: white;
  color: #111;
  padding: 10px 14px;
  font-size: 14px;
  border-radius: 14px;
  border: 2px solid #7aa2ff;
  box-shadow: 0 0 0 3px rgba(122,162,255,.15);
}
/* 📱 SOLO MÓVIL */
@media (max-width: 640px) {
  .input-style {
    padding: 10px 12px;   /* ↓ menos alto */
    font-size: 14px;      /* ↓ texto un poco más chico */
    border-radius: 12px;  /* opcional */
  }
}

  .btn-white-pill {
   /* background: white;
    color: #2702aa; */
    border-radius: 999px;
    font-weight: bold;
    line-height: 1.2;
    transition: 0.3s;
    padding: 0.5rem 1.8rem;
    font-size: 0.9rem;
  }

  .btn-white-pill:hover {
    transform: scale(1.05);
  }
</style>

<script>
  import { config } from "config";
  import { origenCliente } from "@data/origenCliente";
  
  window.__detalleProducto = window.__detalleProducto || null;

  

  /* ================= OBTENER PRODUCTO ================= */
  async function obtenerProductoActual() {
    const container = document.querySelector("#modal2-form-container") as HTMLElement | null;
    const productLink = container?.dataset.productLink;

    if (!productLink) return null;

    if (window.__detalleProducto) return window.__detalleProducto;

    try {
      const response = await fetch(
        `${config.apiUrl}/api/v1/productos/link/${productLink}`,
      );
      if (response.ok) {
        const result = await response.json();
        window.__detalleProducto = result.data || result;
        return window.__detalleProducto;
      }
    } catch (error) {
      console.error("Error obteniendo producto:", error);
    }

    return null;
  }

  /* ================= TÍTULO DINÁMICO ================= */
  function obtenerTituloPopup(producto) {
    const etiqueta = producto?.etiqueta;
    if (!etiqueta) return null;

    if (etiqueta.popup_estilo === "estilo2") {
      return etiqueta.titulo_popup_2 || null;
    }

    return null;
  }

  async function actualizarTituloModal2() {
    const producto = await obtenerProductoActual();
    const titleEl = document.getElementById("modal2-title");
    if (!titleEl) return;

    const tituloBD = obtenerTituloPopup(producto);

    if (tituloBD) {
      titleEl.innerHTML = tituloBD.replace(
        "GRATIS",
        "<span class='font-extrabold'>GRATIS</span>",
      );
    }
  }

  /* ================= IMAGEN DINÁMICA ================= */
  async function actualizarImagenModal2() {
    const container = document.querySelector("#modal2-form-container");
    const modalImg = document.querySelector("#modal2-product-img") as HTMLImageElement | null;
    const modalImg2 = document.querySelector("#modal2-product-img-2") as HTMLImageElement | null;
    if (!container || !modalImg) return;

    const productLink = (container as HTMLElement).dataset.productLink || "";
    let imagen = "/images/popup/default.webp";
    let imagenAlt = "Imagen del producto";
    let imagen2 = "/images/popup/default.webp";
    let imagenAlt2 = "Imagen de fondo";

    if (!window.__detalleProducto && productLink) {
      try {
        const response = await fetch(
          `${config.apiUrl}/api/v1/productos/link/${productLink}`,
        );
        if (response.ok) {
          const result = await response.json();
          window.__detalleProducto = result.data || result;
        }
      } catch {}
    }

    if (window.__detalleProducto) {
      const producto = window.__detalleProducto;
      // Detección más inclusiva (celulares y tablets)
      const isMobileDevice = window.innerWidth < 1024 || window.matchMedia("(max-width: 1023px)").matches;

      // Buscar tipos de imágenes en la colección completa
      const allImages = producto.producto_imagenes || producto.imagenes || [];
      const imgPopup = allImages.find((img: any) => img.tipo === "popup");
      const imgPopup2 = allImages.find((img: any) => img.tipo === "popup2" || img.tipo === "popup_2");
      const imgMobile = allImages.find((img: any) => img.tipo === "popup_mobile");
      const imgMobile2 = allImages.find((img: any) => img.tipo === "popup_mobile2");

      // Imagen de respaldo profesional para productos
      const FALLBACK = "/images/hero/impulso-negocios-tecnologia.webp";

      if (isMobileDevice) {
        // MODO MÓVIL: Prioridad absoluta a imágenes móviles o fallback
        if (imgMobile?.url_imagen) {
          imagen = `${config.apiUrl}${imgMobile.url_imagen}`;
          imagenAlt = imgMobile.texto_alt_SEO || producto.nombre;
        } else {
          imagen = FALLBACK;
          imagenAlt = "Diseño industrial Tami";
        }

        if (imgMobile2?.url_imagen) {
          imagen2 = `${config.apiUrl}${imgMobile2.url_imagen}`;
          imagenAlt2 = imgMobile2.texto_alt_SEO || producto.nombre;
        } else {
          imagen2 = FALLBACK;
          imagenAlt2 = "Diseño industrial Tami";
        }
      } else {
        // MODO ESCRITORIO
        if (imgPopup?.url_imagen) {
          imagen = `${config.apiUrl}${imgPopup.url_imagen}`;
          imagenAlt = imgPopup.texto_alt_SEO || producto.nombre;
        } else if (producto.imagenes?.length > 0) {
          imagen = `${config.apiUrl}${producto.imagenes[0].url_imagen}`;
          imagenAlt = producto.imagenes[0].texto_alt_SEO || producto.nombre;
        }

        if (imgPopup2?.url_imagen) {
          imagen2 = `${config.apiUrl}${imgPopup2.url_imagen}`;
          imagenAlt2 = imgPopup2.texto_alt_SEO || producto.nombre;
        } else {
          imagen2 = imagen;
          imagenAlt2 = imagenAlt;
        }
      }

      // Estilos del boton
      document
        .getElementById("modal2-submit-btn")
        ?.style.setProperty(
          "background",
          producto?.etiqueta?.popup_button_color,
          "important",
        );
      document
        .getElementById("modal2-submit-btn")
        ?.style.setProperty("color", producto?.etiqueta?.popup_text_color);

      const popupButtonText = producto?.etiqueta?.popup_button_text?.trim();
      const submitBtn2 = document.getElementById("modal2-submit-btn");
      if (submitBtn2) {
        submitBtn2.textContent = popupButtonText || "¡Cotiza ahora!";
      }
    }
    

    modalImg.src = imagen;
    modalImg.alt = imagenAlt;
    modalImg.onerror = () => { modalImg.src = "/images/popup/default.webp"; };

    if (modalImg2) {
      modalImg2.src = imagen2;
      modalImg2.alt = imagenAlt2;
      modalImg2.onerror = () => { modalImg2.src = "/images/popup/default.webp"; };
    }

    const titleEl = document.getElementById("modal2-title");
    if (titleEl && window.__detalleProducto) {
       titleEl.innerHTML = (window.__detalleProducto.etiqueta?.titulo_popup_2 || "Tu guía de decoración exclusiva,<br><span class='font-extrabold'>Gratis</span>")
        .replace("Gratis", "<span class='font-extrabold'>Gratis</span>");
    }
  }

  /* ================= CERRAR ================= */
  const modal2 = document.getElementById("modal-detalles-2");
  const closeBtn = document.getElementById("close-modal-detalles-2");

  if (closeBtn) {
    closeBtn.onclick = () => modal2?.classList.add("hidden");
  }

  /* ================= CUANDO SE ABRE ================= */
  if (modal2) {
    const observer = new MutationObserver(async () => {
      if (!modal2.classList.contains("hidden")) {
        await actualizarImagenModal2();
      }
    });

  

    observer.observe(modal2, { attributes: true, attributeFilter: ["class"] });
  }

  /* ================= ENVÍO WHATSAPP + EMAIL ================= */
  const form2 = document.getElementById(
    "form-cotizacion-producto-2",
  ) as HTMLFormElement | null;
  const container2 = document.getElementById(
    "modal2-form-container",
  ) as HTMLElement | null;
  const mensaje2 = document.getElementById("modal2-cotizacion-mensaje");

  const normalizeLeadFormValues = (formElement: HTMLFormElement) => {
    const data = new FormData(formElement);
    return {
      nombre: (data.get("nombre")?.toString() || "").trim(),
      telefono: (data.get("telefono")?.toString() || "")
        .replace(/\D/g, "")
        .trim(),
      correo: (data.get("correo")?.toString() || "").trim(),
    };
  };

  const getLeadValidationMessage = ({
    nombre,
    telefono,
    correo,
  }: {
    nombre: string;
    telefono: string;
    correo: string;
  }) => {
    if (!nombre || nombre.length < 3 || nombre.length > 75) {
      return "Ingresa un nombre valido (3 a 75 caracteres)";
    }

    if (!/^\d{9}$/.test(telefono)) {
      return "Ingresa un telefono valido de 9 digitos";
    }

    if (!correo || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo)) {
      return "Ingresa un correo valido";
    }

    return "";
  };

  const setInlineValidationMessage = (
    formElement: HTMLFormElement,
    message: string,
  ) => {
    const messageEl = formElement.querySelector(
      "[data-validation-message]",
    ) as HTMLElement | null;

    if (!messageEl) return;

    if (message) {
      messageEl.textContent = message;
      messageEl.classList.remove("hidden");
      return;
    }

    messageEl.textContent = "";
    messageEl.classList.add("hidden");
  };

  if (form2 && container2) {
    form2
      .querySelectorAll('input[name="nombre"], input[name="telefono"], input[name="correo"]')
      .forEach((input) => {
        input.addEventListener("input", () => setInlineValidationMessage(form2, ""));
      });

    form2.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitBtn = form2.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement | null;
      const originalBtnText = submitBtn ? submitBtn.textContent : "";

      const { nombre, telefono, correo } = normalizeLeadFormValues(form2);
      const validationMessage = getLeadValidationMessage({
        nombre,
        telefono,
        correo,
      });

      if (validationMessage) {
        setInlineValidationMessage(form2, validationMessage);
        return;
      }

      setInlineValidationMessage(form2, "");

      const telefonoConCodigo = `+51${telefono}`;
      const productLink = container2.dataset.productLink;

      // 1. Estado de carga
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Cotizando...";
      }

      // 2. Cerrar modal rápidamente
      if (modal2) modal2.classList.add("hidden");

      // 3. Notificar al usuario
      window.dispatchEvent(
        new CustomEvent("show-toast", {
          detail: {
            message: "¡Solicitud enviada correctamente!",
            type: "success",
          },
        }),
      );

      // 4. Enviar datos en segundo plano
      try {
        // crear cliente
        const formData = new FormData();
        formData.append("name", nombre);
        formData.append("email", correo);
        formData.append("celular", telefonoConCodigo);
        formData.append("source_id", origenCliente.PRODUCTO_DETALLE);
        formData.append("producto_id", window.__detalleProducto?.id || "");

        const response = await fetch(`${config.apiUrl}${config.endpoints.clientes.create}`, {
          method: "POST",
          body: formData,
        }).catch(() => {});

        if (response && response.ok) {
          const p1 = fetch(`${config.apiUrl}${config.endpoints.whatsapp.info}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              link: productLink,
              phone: telefonoConCodigo,
              email: correo ?? null,
            }),
          }).catch(() => {});

          const p2 = fetch(
            `${config.apiUrl}${config.endpoints.email.sendEmailByProductLink}`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                name: nombre,
                celular: telefonoConCodigo,
                email: correo,
                link: productLink,
              }),
            },
          ).catch(() => {});

          await Promise.all([p1, p2]);
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
        }
        form2.reset();
      }
    });
  }
</script>
