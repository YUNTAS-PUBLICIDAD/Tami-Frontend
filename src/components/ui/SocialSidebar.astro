---
import facebookIcon from "@icons/smi_facebook.svg";
import instagramIcon from "@icons/smi_instagram.svg";
import whatsappIcon from "@icons/smi_whatsapp.svg";
import twitterIcon from "@icons/smi_twitter.svg";
import YoutubeIcon from "@icons/smi_youtube.svg";

const socialLinks = [
  {
    name: "Facebook",
    url: "https://www.facebook.com/tamiperu01",
    icon: facebookIcon,
    bgColor: "bg-[#1877F2]",
    hoverColor: "hover:bg-[#0d65d9]",
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/tami_maquinarias_",
    icon: instagramIcon,
    bgColor: "bg-[#E4405F]",
    hoverColor: "hover:bg-[#d12c4b]",
  },
  {
    name: "WhatsApp",
    url: "https://api.whatsapp.com/send?phone=51978883199&text=Hola%20Tami%2C%20quisiera%20m%C3%A1s%20informaci%C3%B3n%20sobre%20sus%20servicios.",
    icon: whatsappIcon,
    bgColor: "bg-[#25D366]",
    hoverColor: "hover:bg-[#1ebe57]",
  },
  {
    name: "Twitter",
    url: "https://x.com/Tami_Maquinaria",
    icon: twitterIcon,
    bgColor: "bg-[#000000]",
    hoverColor: "hover:bg-[#333333]",
  },
  {
    name: "YouTube",
    url: "https://www.youtube.com/@TamiPeru",
    icon: YoutubeIcon,
    bgColor: "bg-[#FF0000]",
    hoverColor: "hover:bg-[#cc0000]",
  },
];

const pathname = Astro.url.pathname;
if (pathname.startsWith("/admin")) return null;
---

<div class="fixed left-0 top-1/2 -translate-y-1/2 z-50 flex flex-col items-center">
  {socialLinks.map((link) => (
    <a
      href={link.url}
      target="_blank"
      rel="noopener noreferrer"
      class={`w-10 h-10 flex items-center justify-center transition-all duration-300 ${link.bgColor} ${link.hoverColor} text-white shadow-md mb-[2px] last:mb-0 first:rounded-tr-md last:rounded-br-md`}
      aria-label={link.name}
    >
      <img src={link.icon.src} alt={link.name} class="w-6 h-6 object-contain" />
    </a>
  ))}
</div>

<style>
  /* Asegurar que no se oculte en móviles si el usuario lo quiere ver, 
     pero usualmente estas barras se ocultan o se mueven en móviles.
     Por ahora la dejaré visible como pidió el usuario. */
</style>
