---
import whatsappIcon from "@icons/smi_whatsapp.svg";

// Mantenemos tu lógica para que no se renderice en el panel de administración
const pathname = Astro.url.pathname;
if (pathname.startsWith("/admin")) return null;

const whatsappUrl = "https://api.whatsapp.com/send?phone=51978883199&text=Hola%20Tami%2C%20quisiera%20m%C3%A1s%20informaci%C3%B3n%20sobre%20sus%20servicios.";
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  title="Contactar por WhatsApp"
  class="fixed bottom-6 left-6 z-50 flex md:hidden items-center justify-center w-14 h-14 bg-[#25D366] hover:bg-[#1ebe57] text-white rounded-full shadow-lg transition-all duration-300 hover:scale-110 motion-safe:animate-bounce-slow"
>
  <img src={whatsappIcon.src} alt="WhatsApp" class="w-7 h-7" />
</a>

<style>
  /* Animación sutil para llamar la atención sin ser molesta */
  @keyframes bounceSlow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  
  .motion-safe\:animate-bounce-slow {
    @media (prefers-reduced-motion: no-preference) {
      animation: bounceSlow 3s infinite ease-in-out;
    }
  }
</style>