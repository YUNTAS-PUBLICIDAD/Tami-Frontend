---
import WhatsappEditor from "./WhatsappEditor";
---
<div
    id="contentWhatsapp"
    class="hidden space-y-8"
>
    <!-- Selector de Mensaje -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 p-4 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"></path>
                </svg>
            </div>
            <h3 class="font-bold text-gray-900 dark:text-gray-100">Configuración:</h3>
        </div>
        
        <select 
            id="whatsappMessageSelector"
            class="w-full sm:w-64 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-xl px-4 py-2.5 text-sm font-semibold text-gray-700 dark:text-gray-200 shadow-sm focus:ring-2 focus:ring-emerald-500 outline-none transition-all cursor-pointer"
        >
            <option value="1">🟢 WhatsApp Mensaje 1</option>
            <option value="2">🟡 WhatsApp Mensaje 2</option>
            <option value="3">🟠 WhatsApp Mensaje 3</option>
        </select>
    </div>

    <!-- Mensaje 1 -->
    <div id="waBlock1" class="wa-message-block space-y-6">
        <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm space-y-6">
        <div class="flex items-center gap-3 border-b border-gray-50 dark:border-gray-700/50 pb-4">
            <div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400 shrink-0">
                <span class="font-bold">1</span>
            </div>
            <div>
                <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg">Primer Mensaje</h3>
                <p class="text-xs text-gray-500 dark:text-gray-400">Mensaje que se enviará al instante tras la suscripción.</p>
            </div>
        </div>

        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Imagen 1 -->
                <div class="space-y-3">
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Imagen del Mensaje 1</label>
                    <div class="flex items-center gap-3">
                        <input type="hidden" name="delete_whatsappImage" id="delete_whatsappImage" value="0" />
                        <input type="file" id="whatsappImage" accept="image/*" class="hidden" />
                        <button
                            type="button"
                            onclick="document.getElementById('whatsappImage').click()"
                            class="inline-flex items-center px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-all shadow-md active:scale-95"
                        >
                            Subir Imagen
                        </button>
                        <button
                            type="button"
                            id="clearWhatsappImage"
                            class="hidden p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Tiempo 1 -->
                <div class="space-y-3">
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Tiempo de aparición (minutos)</label>
                    <input 
                        type="number" 
                        id="whatsappTime1" 
                        min="0" 
                        placeholder="0" 
                        class="w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg p-2.5 text-sm focus:ring-2 focus:ring-emerald-500 transition-all outline-none"
                    />
                    <p class="text-[10px] text-gray-500 italic">Recomendado: 0 para envío inmediato.</p>
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Mensaje de WhatsApp</label>
                <WhatsappEditor client:load inputId="whatsappMessage" updateEventName="update-whatsapp-editor-1" previewEventName="update-whatsapp-preview" />
            </div>
        </div>
        </div>
    </div>

    <!-- Mensaje 2 -->
    <div id="waBlock2" class="wa-message-block space-y-6 hidden">
        <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm space-y-6">
        <div class="flex items-center gap-3 border-b border-gray-50 dark:border-gray-700/50 pb-4">
            <div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400 shrink-0">
                <span class="font-bold">2</span>
            </div>
            <div>
                <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg">Segundo Mensaje</h3>
                <p class="text-xs text-gray-500 dark:text-gray-400">Mensaje secuencial después del primero.</p>
            </div>
        </div>

        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Imagen 2 -->
                <div class="space-y-3">
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Imagen del Mensaje 2</label>
                    <div class="flex items-center gap-3">
                        <input type="hidden" name="delete_whatsappImage2" id="delete_whatsappImage2" value="0" />
                        <input type="file" id="whatsappImage2" accept="image/*" class="hidden" />
                        <button
                            type="button"
                            onclick="document.getElementById('whatsappImage2').click()"
                            class="inline-flex items-center px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-all shadow-md active:scale-95"
                        >
                            Subir Imagen
                        </button>
                        <button
                            type="button"
                            id="clearWhatsappImage2"
                            class="hidden p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Tiempo 2 -->
                <div class="space-y-3">
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Tiempo de espera (minutos)</label>
                    <input 
                        type="number" 
                        id="whatsappTime2" 
                        min="0" 
                        placeholder="30" 
                        class="w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg p-2.5 text-sm focus:ring-2 focus:ring-emerald-500 transition-all outline-none"
                    />
                    <p class="text-[10px] text-gray-500 italic">Tiempo después de haber enviado el primer mensaje.</p>
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Mensaje de WhatsApp</label>
                <WhatsappEditor client:load inputId="whatsappMessage2" updateEventName="update-whatsapp-editor-2" previewEventName="update-whatsapp-preview-2" />
            </div>
        </div>
        </div>
    </div>

    <!-- Mensaje 3 -->
    <div id="waBlock3" class="wa-message-block space-y-6 hidden">
        <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm space-y-6">
        <div class="flex items-center gap-3 border-b border-gray-50 dark:border-gray-700/50 pb-4">
            <div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400 shrink-0">
                <span class="font-bold">3</span>
            </div>
            <div>
                <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg">Tercer Mensaje</h3>
                <p class="text-xs text-gray-500 dark:text-gray-400">Último mensaje de la secuencia.</p>
            </div>
        </div>

        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Imagen 3 -->
                <div class="space-y-3">
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Imagen del Mensaje 3</label>
                    <div class="flex items-center gap-3">
                        <input type="hidden" name="delete_whatsappImage3" id="delete_whatsappImage3" value="0" />
                        <input type="file" id="whatsappImage3" accept="image/*" class="hidden" />
                        <button
                            type="button"
                            onclick="document.getElementById('whatsappImage3').click()"
                            class="inline-flex items-center px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-all shadow-md active:scale-95"
                        >
                            Subir Imagen
                        </button>
                        <button
                            type="button"
                            id="clearWhatsappImage3"
                            class="hidden p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Tiempo 3 -->
                <div class="space-y-3">
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Tiempo de espera (minutos)</label>
                    <input 
                        type="number" 
                        id="whatsappTime3" 
                        min="0" 
                        placeholder="60" 
                        class="w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg p-2.5 text-sm focus:ring-2 focus:ring-emerald-500 transition-all outline-none"
                    />
                    <p class="text-[10px] text-gray-500 italic">Tiempo después de haber enviado el segundo mensaje.</p>
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Mensaje de WhatsApp</label>
                <WhatsappEditor client:load inputId="whatsappMessage3" updateEventName="update-whatsapp-editor-3" previewEventName="update-whatsapp-preview-3" />
            </div>
        </div>
    </div>
</div>
</div>
